        if [ $status -gt 128 ]; then
            continue
        fi
        
        if [ "$cmd" = "exit" ] || [ "$cmd" = "quit" ] || [ "$cmd" = "quit_console" ]; then
            break
        fi
        
        if [ -n "$cmd" ]; then
            screen -S "$session_name" -p 0 -X stuff "${cmd}$(printf \\r)"
            sleep 0.15
        fi
    done
}

