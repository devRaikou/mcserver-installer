connect_server_console() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    local log_file="${server_path}/logs/latest.log"

    if ! is_server_running "$session_name"; then
        log_error "Server is not running. Start the server first!"
        sleep 2
        return 1
    fi

    local port; port=$(get_server_port "$server_path" "standard")
    local local_ip; local_ip=$(get_local_ip)
    local public_ip="Unknown"
    if [ -f "${CONFIG_DIR}/.public_ip" ]; then
        public_ip=$(cat "${CONFIG_DIR}/.public_ip" 2>/dev/null)
    fi
    [ -z "$public_ip" ] && public_ip="Unknown"

    while true; do
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_interactive_console" "INTERACTIVE CONSOLE")${COLOR_RESET} (Type 'exit' to quit console)"
        echo -e "  Address:  ${COLOR_GREEN}${local_ip}:${port}${COLOR_RESET} (Local) | ${COLOR_GREEN}${public_ip}:${port}${COLOR_RESET} (Public)"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"

        if [ -f "$log_file" ]; then
            tail -n 18 "$log_file"
        else
            echo "  No log file found at $log_file"
        fi
        echo -e "${COLOR_CYAN}────────────────────────────────────────────────────────────────${COLOR_RESET}"

        local cmd=""
        echo -n -e "${COLOR_YELLOW}[Console Input]${COLOR_RESET} > " >&2
        read -t 1.5 -r cmd

        local status=$?
        if [ $status -gt 128 ]; then
            continue
        fi

        if [ "$cmd" = "exit" ] || [ "$cmd" = "quit" ] || [ "$cmd" = "quit_console" ]; then
            break
        fi

        if [ -n "$cmd" ]; then
            screen -S "$session_name" -p 0 -X stuff "${cmd}$(printf \\r)"
            sleep 0.15
        fi
    done
}

