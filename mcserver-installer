                        log_error "Lütfen yedeği geri yüklemeden önce sunucuyu durdurun!"
                    else
                        log_error "Please stop the server before running a restore!"
                    fi
                    sleep 2
                else
                    run_server_restore "$s_path"
                fi
                ;;
            11)
                if [ ! -f "${s_path}/start.sh" ]; then
                    if [ "$LANG_PREF" = "tr" ]; then
                        log_error "Bellek miktarlarını değiştirmek için start.sh betiği bulunamadı."
                    else
                        log_error "No start.sh script found to modify memory values."
                    fi
                    sleep 2
                else
                    clear_screen
                    draw_header
                    if [ "$LANG_PREF" = "tr" ]; then
                        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}BELLEK YAPILANDIRMASINI DEĞİŞTİR${COLOR_RESET}\n"
                        local min_ram; min_ram=$(prompt_ram_input "Yeni Minimum RAM miktarını girin" "1024M")
                        local max_ram; max_ram=$(prompt_ram_input "Yeni Maksimum RAM miktarını girin" "4096M")
                    else
                        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}CHANGE MEMORY CONFIGURATION${COLOR_RESET}\n"
                        local min_ram; min_ram=$(prompt_ram_input "Enter new Minimum RAM allocation" "1024M")
                        local max_ram; max_ram=$(prompt_ram_input "Enter new Maximum RAM allocation" "4096M")
                    fi

                    if [[ "$OSTYPE" == "darwin"* ]]; then
                        sed -i '' "s|^MEM_MIN=.*|MEM_MIN=\"${min_ram}\"|" "${s_path}/start.sh"
                        sed -i '' "s|^MEM_MAX=.*|MEM_MAX=\"${max_ram}\"|" "${s_path}/start.sh"
                    else
                        sed -i "s|^MEM_MIN=.*|MEM_MIN=\"${min_ram}\"|" "${s_path}/start.sh"
                        sed -i "s|^MEM_MAX=.*|MEM_MAX=\"${max_ram}\"|" "${s_path}/start.sh"
                    fi

                    if [ -f "${s_path}/user_jvm_args.txt" ]; then
                        if [[ "$OSTYPE" == "darwin"* ]]; then
                            sed -i '' "s|-Xms.*|-Xms${min_ram}|" "${s_path}/user_jvm_args.txt"
                            sed -i '' "s|-Xmx.*|-Xmx${max_ram}|" "${s_path}/user_jvm_args.txt"
                        else
                            sed -i "s|-Xms.*|-Xms${min_ram}|" "${s_path}/user_jvm_args.txt"
                            sed -i "s|-Xmx.*|-Xmx${max_ram}|" "${s_path}/user_jvm_args.txt"
                        fi
                    fi

                    if [ "$LANG_PREF" = "tr" ]; then
                        log_success "Bellek sınırları başarıyla güncellendi!"
                    else
                        log_success "Memory values updated successfully!"
                    fi
                    sleep 2
                fi
                ;;
            12)
                optimize_server_performance "$s_path" "$s_type"
                ;;
            13)
                monitor_server_resources "$s_name" "$s_path"
                ;;
            14)
                manage_server_plugins "$s_name" "$s_path" "$s_type" "$s_ver"
                ;;
            15)
                install_geyser_floodgate "$s_name" "$s_path" "$s_type" "$s_ver"
                ;;
            16)
                toggle_systemd_service "$s_name" "$s_path"
                ;;
            17)
                break
                ;;
            *)
                log_warn "$(t "invalid_sel" "Invalid selection.")"
                sleep 1
                ;;
        esac
    done
}

select_and_manage_server() {
    local action="${1:-manage}"
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        log_warn "No installed servers registered."
        sleep 2
        return 1
    fi

    clear_screen
    draw_header
    local title
    case "$action" in
        backup) title="$(t "hdr_backup_creation" "BACKUP CREATION")" ;;
        restore) title="$(t "hdr_restore_backup" "RESTORE BACKUP")" ;;
        *) title="$(t "hdr_select_server" "SELECT INSTALLED SERVER")" ;;
    esac
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}${title}${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    # Read registry
    local servers=()
    local paths=()
    local types=()
    local versions=()
    local list_options=()

    local i=1
    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        # Skip empty lines
        [ -z "$name" ] && continue

        servers+=("$name")
        paths+=("$path")
        types+=("$type")
        versions+=("$version")

        # Check active status
        local sess; sess=$(get_session_name "$path")
        local status="${COLOR_RED}[Stopped]${COLOR_RESET}"
        if is_server_running "$sess"; then
            status="${COLOR_GREEN}[Running]${COLOR_RESET}"
        fi

        list_options+=("$name ($type $version) - $path $status")
        i=$((i + 1))
    done < "$REGISTRY_FILE"

    if [ ${#servers[@]} -eq 0 ]; then
        log_warn "No valid servers registered in the registry."
        sleep 2
        return 1
    fi

    list_options+=("$(t "settings_back" "Return to Main Menu")")
    local selection
    selection=$(prompt_selection "$(t "prompt_manage_server" "Choose server to manage:")" "${list_options[@]}")

    if [ "$selection" = "$(t "settings_back" "Return to Main Menu")" ]; then
        return 0
    fi

    # Find matching index
    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done

    if [ "$idx" -ne -1 ]; then
        case "$action" in
            backup)
                create_server_backup "${paths[$idx]}"
                ;;
            restore)
                local sess
                sess=$(get_session_name "${paths[$idx]}")
                if is_server_running "$sess"; then
                    if [ "$LANG_PREF" = "tr" ]; then
                        log_error "Lütfen yedeği geri yüklemeden önce sunucuyu durdurun!"
                    else
                        log_error "Please stop the server before running a restore!"
                    fi
                    sleep 2
                else
                    run_server_restore "${paths[$idx]}"
                fi
                ;;
            *)
                run_server_management_menu "${servers[$idx]}" "${paths[$idx]}" "${types[$idx]}" "${versions[$idx]}"
                ;;
        esac
    fi
}

