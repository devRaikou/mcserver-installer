        echo -e "    ${COLOR_YELLOW}9.${COLOR_RESET} $(t "main_exit" "Exit")"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        
        echo -n "  $(t "main_select" "Select option (1-9):") "
        read -r choice
        choice=$(echo "$choice" | tr -d '\r')
        
        case "$choice" in
            1)
                run_installation_wizard
                ;;
            2)
                select_and_manage_server
                ;;
            3)
                update_server_software
                ;;
            4)
                select_and_manage_server
                ;;
            5)
                select_and_manage_server
                ;;
            6)
                remove_server_registration
                ;;
            7)
                run_settings_menu
                ;;
            8)
                show_about
                ;;
            9)
                if [ "$LANG_PREF" = "tr" ]; then
                    echo -e "\n  ${COLOR_CYAN}mcserver-installer${COLOR_RESET} kullandığınız için teşekkürler! Görüşmek üzere."
                else
                    echo -e "\n  Thank you for using ${COLOR_CYAN}mcserver-installer${COLOR_RESET}! Goodbye."
                fi
                exit 0
                ;;
            *)
                if [ "$LANG_PREF" = "tr" ]; then
                    log_warn "Geçersiz seçim. Lütfen 1 ile 9 arasında bir sayı girin."
                else
                    log_warn "Invalid selection. Please input a number from 1 to 9."
                fi
                sleep 1.5
                ;;
        esac
    done
}

# --- Command Line Argument Parser (Headless Execution) ---
if [ $# -gt 0 ]; then
    if [ "$1" = "--backup" ]; then
        if [ $# -lt 2 ]; then
            echo "Usage: $0 --backup <server_name>" >&2
            exit 1
        fi
        
        HEADLESS_MODE="true"
        target_name="$2"
        if [ -f "$REGISTRY_FILE" ]; then
            line=$(grep "^${target_name}:" "$REGISTRY_FILE" | head -n 1)
            if [ -n "$line" ]; then
                s_path=$(echo "$line" | cut -d: -f2)
                create_server_backup "$s_path"
                exit $?
            else
                echo "Error: Server '${target_name}' not found in registry." >&2
                exit 1
            fi
        else
            echo "Error: Registry file is empty or does not exist." >&2
            exit 1
        fi
    else
        echo "Unknown argument: $1" >&2
        echo "Usage: $0 [--backup <server_name>]" >&2
        exit 1
    fi
fi

# Launch Application
HEADLESS_MODE="false"
main_menu
