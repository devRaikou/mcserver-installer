# --- Installation Wizard ---
run_installation_wizard() {
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_install_wizard" "INSTALLATION WIZARD")${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    local back_opt
    back_opt=$(t "settings_back" "Return to Main Menu")

    # 1. Server Type
    local types=(Vanilla Paper Folia Purpur Fabric Forge NeoForge Velocity Waterfall BungeeCord "$back_opt")
    local s_type
    s_type=$(prompt_selection "$(t "prompt_software_type" "Choose Minecraft server software type:")" "${types[@]}")
    if [ "$s_type" = "$back_opt" ] || [ -z "$s_type" ]; then
        return 0
    fi
    s_type=$(echo "$s_type" | tr '[:upper:]' '[:lower:]')

    # 2. Minecraft Version & Software fetch
    local mc_version=""
    local download_url=""
    local build_num=""
    local loader_version=""

    TMP_WIZARD_DIR=$(mktemp -d)

    case "$s_type" in
        vanilla)
            log_info "Fetching Minecraft Vanilla versions..."
            local releases
            releases=$(fetch_vanilla_releases)
            local list_options=()
            for r in $releases; do list_options+=("$r"); done
            list_options+=("$back_opt")
            mc_version=$(prompt_selection "$(t "prompt_mc_version" "Select Minecraft version:")" "${list_options[@]}")
            if [ "$mc_version" = "$back_opt" ] || [ -z "$mc_version" ]; then
                rm -rf "$TMP_WIZARD_DIR" 2>/dev/null
                return 0
            fi

            log_info "Resolving download URL for Vanilla $mc_version..."
            download_url=$(fetch_vanilla_download_url "$mc_version")
            ;;
        paper|folia|velocity|waterfall)
            log_info "Fetching $s_type versions..."
            local versions
            versions=$(fetch_papermc_versions "$s_type")
            local list_options=()
            for v in $versions; do list_options+=("$v"); done
            list_options+=("$back_opt")
            mc_version=$(prompt_selection "$(t "prompt_mc_version" "Select Minecraft version:")" "${list_options[@]}")
