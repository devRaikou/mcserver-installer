# --- Backup & Restore Subsystem ---
create_server_backup() {
    local server_path="$1"
    local backup_dir="${server_path}/backups"
    mkdir -p "$backup_dir"
    
    if [ "${HEADLESS_MODE:-false}" = "false" ]; then
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}BACKUP CREATION${COLOR_RESET}"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    fi
    
    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local tar_name="backup_${timestamp}.tar.gz"
    local tar_path="${backup_dir}/${tar_name}"
    
    log_info "Creating backup archive in progress..."
    
    (cd "$server_path" && tar --exclude='./backups' --exclude='./logs' -czf "$tar_path" .)
    local status=$?
    
    if [ $status -eq 0 ]; then
        local size_bytes
        if [[ "$OSTYPE" == "darwin"* ]]; then
            size_bytes=$(stat -f %z "$tar_path")
        else
            size_bytes=$(stat -c %s "$tar_path")
        fi
        local size_mb=$((size_bytes / 1024 / 1024))
        log_success "Backup completed successfully!"
        log_success "Saved as: backups/${tar_name} (${size_mb} MB)"
        send_discord_notification "💾 Backup created successfully!" 3066993 "$server_path" "Backup Archive" "${tar_name} (${size_mb} MB)"
    else
        log_error "Backup compression failed."
        send_discord_notification "⚠️ Backup compression failed!" 15158332 "$server_path"
    fi
    
    if [ "${HEADLESS_MODE:-false}" = "false" ]; then
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
    fi
}

manage_backup_scheduler() {
    local s_name="$1"
    local s_path="$2"
    
    while true; do
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}AUTOMATED BACKUP SCHEDULER${COLOR_RESET}"
        echo -e "  Server: $s_name"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
        
        local current_cron
        current_cron=$(crontab -l 2>/dev/null | grep "mcserver-installer --backup ${s_name}" || true)
        
        if [ -n "$current_cron" ]; then
            echo -e "  Active Schedule: ${COLOR_GREEN}${current_cron}${COLOR_RESET}"
        else
            echo -e "  Active Schedule: ${COLOR_YELLOW}None (Disabled)${COLOR_RESET}"
        fi
        
        echo -e "\n  Options:"
        echo -e "    ${COLOR_YELLOW}1.${COLOR_RESET} Schedule Daily Backup (at 04:00 AM)"
        echo -e "    ${COLOR_YELLOW}2.${COLOR_RESET} Schedule Weekly Backup (Sundays at 04:00 AM)"
        echo -e "    ${COLOR_YELLOW}3.${COLOR_RESET} Remove Automated Backup Schedule"
        echo -e "    ${COLOR_YELLOW}4.${COLOR_RESET} Return to Management Menu"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        
        local choice
        choice=$(prompt_input "Select option" "4")
        
        local script_path
        script_path=$(cd "$(dirname "$0")" && pwd)/$(basename "$0")
        
        case "$choice" in
            1)
                local schedule_line="0 4 * * * \"${script_path}\" --backup \"${s_name}\" >/dev/null 2>&1"
                (crontab -l 2>/dev/null | grep -v "mcserver-installer --backup ${s_name}"; echo "$schedule_line") | crontab -
                log_success "Daily backup successfully scheduled!"
                sleep 2
                ;;
            2)
                local schedule_line="0 4 * * 0 \"${script_path}\" --backup \"${s_name}\" >/dev/null 2>&1"
                (crontab -l 2>/dev/null | grep -v "mcserver-installer --backup ${s_name}"; echo "$schedule_line") | crontab -
                log_success "Weekly backup successfully scheduled!"
                sleep 2
                ;;
            3)
                crontab -l 2>/dev/null | grep -v "mcserver-installer --backup ${s_name}" | crontab - || crontab -r 2>/dev/null
                log_success "Automated backup schedule removed."
                sleep 2
                ;;
            4)
                break
                ;;
            *)
                log_warn "Invalid selection."
                sleep 1.5
                ;;
        esac
    done
}

run_server_restore() {
    local server_path="$1"
    local backup_dir="${server_path}/backups"
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}RESTORE BACKUP${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    if [ ! -d "$backup_dir" ] || [ -z "$(ls -A "$backup_dir" 2>/dev/null)" ]; then
        log_warn "No backups found for this server."
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 1
    fi
    
    local backups_list=()
    for f in "$backup_dir"/backup_*.tar.gz; do
        if [ -f "$f" ]; then
            backups_list+=("$(basename "$f")")
        fi
    done
    
    if [ ${#backups_list[@]} -eq 0 ]; then
        log_warn "No valid backups found."
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 1
    fi
    
    # Sort backups in descending order (newest first)
    IFS=$'\n' sorted_backups=($(sort -r <<<"${backups_list[*]}"))
    unset IFS
    
    local chosen_backup
    chosen_backup=$(prompt_selection "Select backup to restore:" "${sorted_backups[@]}")
    local full_backup_path="${backup_dir}/${chosen_backup}"
    
    log_warn "RESTORE ACTION IS DESTRUCTIVE!"
    log_warn "This will overwrite your existing world files, properties, and configurations."
    prompt_yes_no "Are you absolutely sure you want to restore ${chosen_backup}?" "n"
    if [ $? -ne 0 ]; then
        log_info "Restore canceled."
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 0
    fi
    
    # We remove worlds and configs but keep logs and backup folder safe
    log_info "Clearing directory for restore..."
    find "$server_path" -maxdepth 1 -not -name "backups" -not -name "logs" -not -name "." -not -name ".." -exec rm -rf {} +
    
    log_info "Extracting backup content..."
    tar -xzf "$full_backup_path" -C "$server_path"
    local status=$?
    
    if [ $status -eq 0 ]; then
        log_success "Backup restored successfully!"
        log_info "Please verify the start script and java configurations before starting."
    else
        log_error "Failed to extract backup file correctly."
    fi
    
    echo -e -n "\n  Press [Enter] to return: "
    read -r _
}

# --- Server Lifecycle & Console Manager ---

get_session_name() {
    local s_path="$1"
    local hash
    if command -v md5sum &>/dev/null; then
        hash=$(echo -n "$s_path" | md5sum | cut -c1-8)
    else
        hash=$(echo -n "$s_path" | md5 | cut -c1-8)
    fi
    local name
    name=$(basename "$s_path" | tr -cd 'a-zA-Z0-9_-')
    echo "mc-${name}-${hash}"
}

is_server_running() {
    local session_name="$1"
    screen -list | grep -q "\.${session_name}"
}

check_firewall_rules() {
    local port="$1"
    if command -v ufw &>/dev/null; then
        local status
        status=$(sudo ufw status 2>/dev/null || ufw status 2>/dev/null || echo "inactive")
        if echo "$status" | grep -q "Status: active"; then
            if ! echo "$status" | grep -q "${port}"; then
                log_warn "UFW firewall is active but port ${port} is NOT allowed!"
                echo -n "  Would you like to open port ${port} in UFW automatically? [Y/n]: " >&2
                local choice
                read -r choice
                if [[ ! "$choice" =~ ^[Nn] ]]; then
                    local open_cmd="ufw allow ${port}/tcp && ufw allow ${port}/udp && ufw reload"
                    if [ "$EUID" -eq 0 ]; then
                        run_with_spinner "Opening port ${port} in UFW" bash -c "$open_cmd"
                    else
                        run_with_spinner "Opening port ${port} in UFW (via sudo)" sudo bash -c "$open_cmd"
                    fi
                fi
            else
                log_success "UFW firewall rule check: Port ${port} is already allowed."
            fi
        fi
    fi
}

start_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if is_server_running "$session_name"; then
        log_warn "Server is already running in screen session: $session_name"
        sleep 2
        return 1
    fi
    
    local s_type="standard"
    if [ -f "${server_path}/velocity.toml" ]; then
        s_type="velocity"
    elif [ -f "${server_path}/config.yml" ]; then
        s_type="bungeecord"
    fi
    local port; port=$(get_server_port "$server_path" "$s_type")
    check_firewall_rules "$port"
    
    log_info "Starting server..."
    rm -f "${server_path}/.stop_restart"
    
    (cd "$server_path" && screen -dmS "$session_name" ./start.sh)
    
    sleep 2
    if is_server_running "$session_name"; then
        log_success "Server started successfully in background!"
        log_info "Screen session: $session_name"
        send_discord_notification "🟢 Server has started successfully!" 3066993 "$server_path"
    else
        log_error "Server failed to start. Check your logs/latest.log or start.sh."
    fi
    sleep 2
}

stop_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if ! is_server_running "$session_name"; then
        log_warn "Server is not running."
        sleep 2
        return 1
    fi
    
    log_info "Sending stop command to server..."
    touch "${server_path}/.stop_restart"
    
    screen -S "$session_name" -p 0 -X stuff "stop$(printf \\r)"
    
    local count=0
    printf "  Waiting for server to stop gracefully "
    while is_server_running "$session_name" && [ $count -lt 30 ]; do
        printf "."
        sleep 1
        count=$((count + 1))
    done
    printf "\n"
    
    if is_server_running "$session_name"; then
        log_warn "Server did not stop gracefully. Forcing termination..."
        screen -S "$session_name" -p 0 -X quit
        pkill -f "java.*${session_name}"
        send_discord_notification "🔴 Server did not stop gracefully. Forced termination applied." 15158332 "$server_path"
    else
        log_success "Server stopped gracefully."
        send_discord_notification "🔴 Server has stopped gracefully." 15158332 "$server_path"
    fi
    rm -f "${server_path}/.stop_restart"
    sleep 2
}

restart_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if is_server_running "$session_name"; then
        stop_minecraft_server "$server_path"
    fi
    start_minecraft_server "$server_path"
}

