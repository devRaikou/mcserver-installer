        if is_server_running "$session_name"; then
            status_str="${COLOR_GREEN}$(t "running" "Running")${COLOR_RESET}"
        fi

        local port; port=$(get_server_port "$s_path" "$s_type")
        local local_ip; local_ip=$(get_local_ip)
