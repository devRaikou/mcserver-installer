# Spinner logic for background operations
run_with_spinner() {
    local msg="$1"
    shift
    
    local tmp_out
    local tmp_err
    tmp_out=$(mktemp)
    tmp_err=$(mktemp)
    
    # Run the command in the background
    "$@" >"$tmp_out" 2>"$tmp_err" &
    local pid=$!
    
    local delay=0.1
    local spinstr='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    printf "  ${COLOR_CYAN}%s${COLOR_RESET} " "$msg"
    while kill -0 "$pid" 2>/dev/null; do
        local temp=${spinstr#?}
        printf "${COLOR_MAGENTA}%c${COLOR_RESET}" "$spinstr"
        spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\b"
    done
    
    wait "$pid"
    local status=$?
    printf "\b \b\r" # Clear the spinner char
    
    if [ $status -eq 0 ]; then
        echo -e "  ${COLOR_GREEN}${ICON_SUCCESS} ${msg} - Done!${COLOR_RESET}"
        cat "$tmp_out"
        rm -f "$tmp_out" "$tmp_err"
        return 0
    else
        echo -e "  ${COLOR_RED}${ICON_ERROR} ${msg} - Failed!${COLOR_RESET}"
        if [ -s "$tmp_err" ]; then
            echo -e "    ${COLOR_RED}Error: $(cat "$tmp_err")${COLOR_RESET}"
        fi
        rm -f "$tmp_out" "$tmp_err"
        return 1
    fi
}

# Cross-platform file downloader with a stylized progress bar
download_file_with_progress() {
    local url="$1"
    local dest="$2"
    local label="$3"
    
    # Get Content-Length size of download in bytes
    local total_bytes
    total_bytes=$(curl -sIL "$url" | grep -i "^content-length" | awk '{print $2}' | tr -d '\r\n')
    
    if [ -z "$total_bytes" ] || [ "$total_bytes" -le 0 ]; then
        # Fallback to spinner download if we cannot fetch size
        run_with_spinner "Downloading $label" curl -s -L -o "$dest" "$url"
        return $?
    fi
    
    # Start download backgrounded
    curl -s -L -o "$dest" "$url" &
    local pid=$!
    
    local width=35
    echo -e "  ${COLOR_CYAN}Downloading: ${COLOR_WHITE}$label${COLOR_RESET}"
    
    # Progress loop
    while kill -0 "$pid" 2>/dev/null; do
        local current_bytes=0
        if [ -f "$dest" ]; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                current_bytes=$(stat -f %z "$dest" 2>/dev/null || echo 0)
            else
                current_bytes=$(stat -c %s "$dest" 2>/dev/null || echo 0)
            fi
        fi
        
        local pct=$(( current_bytes * 100 / total_bytes ))
        if [ $pct -gt 100 ]; then pct=100; fi
        
        local filled=$(( pct * width / 100 ))
        local empty=$(( width - filled ))
        
        local bar_filled=""
        if [ $filled -gt 0 ]; then
            bar_filled=$(printf '█%.0s' $(seq 1 $filled))
        fi
        
        local bar_empty=""
        if [ $empty -gt 0 ]; then
            bar_empty=$(printf '░%.0s' $(seq 1 $empty))
        fi
        
        local current_mb=$((current_bytes / 1048576))
        local total_mb=$((total_bytes / 1048576))
        
        printf "\r  ${COLOR_MAGENTA}[%s%s]${COLOR_RESET} %d%% (%d/%d MB)" "$bar_filled" "$bar_empty" "$pct" "$current_mb" "$total_mb"
        sleep 0.1
    done
    
    wait "$pid"
    local status=$?
    
    local bar_full
    bar_full=$(printf '█%.0s' $(seq 1 $width))
    local final_mb=$((total_bytes / 1048576))
    
    if [ $status -eq 0 ]; then
        printf "\r  ${COLOR_GREEN}[%s] 100%% (%d/%d MB) - Complete!${COLOR_RESET}\n" "$bar_full" "$final_mb" "$final_mb"
        return 0
    else
        printf "\r  ${COLOR_RED}[%s%s] Failed!                       ${COLOR_RESET}\n" "$bar_filled" "$bar_empty"
        log_error "Download interrupted."
        return 1
    fi
}

# --- System Validation Checks ---
verify_system_requirements() {
    draw_box_open "System Verification"
    
    # 1. OS check
    if [ -f /etc/os-release ]; then
        local os_name
        os_name=$(grep -i '^id=' /etc/os-release | cut -d= -f2 | tr -d '"')
        if [[ "$os_name" != "ubuntu" && "$os_name" != "debian" ]]; then
            log_warn "This script is optimized for Ubuntu/Debian. Running in compatibility mode."
        else
            log_success "Operating System: Ubuntu/Debian compatible ($os_name)"
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        log_warn "macOS detected. Running in Darwin compatibility mode."
    else
        log_warn "Unknown OS detected. Proceeding with caution."
    fi
    
    # 2. Check essential packages
    local missing_deps=()
    for dep in curl jq screen tar gzip; do
        if ! command -v "$dep" &>/dev/null; then
            missing_deps+=("$dep")
        fi
    done
    
    if [ ${#missing_deps[@]} -gt 0 ]; then
        log_warn "Missing required packages: ${missing_deps[*]}"
        if [[ "$OSTYPE" == "darwin"* ]]; then
            log_error "Please install these tools manually via Homebrew: brew install ${missing_deps[*]}"
            draw_box_close
            exit 1
        fi
        
        # Check permissions to install
        if [ "$EUID" -ne 0 ] && ! command -v sudo &>/dev/null; then
            log_error "Root permissions or sudo required to install dependencies: ${missing_deps[*]}"
            draw_box_close
            exit 1
        fi
        
        echo -n "  Would you like to install the missing dependencies automatically? [Y/n]: "
        read -r choice
        if [[ "$choice" =~ ^[Nn] ]]; then
            log_error "Cannot proceed without dependencies."
            draw_box_close
            exit 1
        fi
        
        local pkg_mgr_cmd="apt-get update && apt-get install -y ${missing_deps[*]}"
        if [ "$EUID" -eq 0 ]; then
            run_with_spinner "Installing dependencies" bash -c "$pkg_mgr_cmd"
        else
            run_with_spinner "Installing dependencies (via sudo)" sudo bash -c "$pkg_mgr_cmd"
        fi
        
        if [ $? -ne 0 ]; then
            log_error "Dependency installation failed."
            draw_box_close
            exit 1
        fi
    else
        log_success "All CLI dependencies are present (curl, jq, screen, tar, gzip)"
    fi
    
    # 3. Disk space validation
    local df_path="."
    local avail_kb
    if [[ "$OSTYPE" == "darwin"* ]]; then
        avail_kb=$(df -k "$df_path" | tail -n 1 | awk '{print $4}')
    else
        avail_kb=$(df -k "$df_path" | tail -n 1 | awk '{print $4}')
    fi
    local avail_gb=$((avail_kb / 1024 / 1024))
    if [ "$avail_gb" -lt 5 ]; then
        log_warn "Low disk space: Only ${avail_gb}GB available. A minimum of 5GB is recommended."
    else
        log_success "Available disk space: ${avail_gb}GB (Recommended >= 5GB)"
    fi
    
    # 4. RAM validation
    local total_ram_mb=0
    if [[ "$OSTYPE" == "darwin"* ]]; then
        local bytes
        bytes=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
        total_ram_mb=$((bytes / 1024 / 1024))
    else
        total_ram_mb=$(free -m | awk '/^Mem:/{print $2}' 2>/dev/null || grep MemTotal /proc/meminfo | awk '{print int($2/1024)}' || echo 0)
    fi
    
    if [ "$total_ram_mb" -lt 2048 ]; then
        log_warn "Low system memory: $((total_ram_mb / 1024))GB RAM detected. Recommended >= 2GB."
    else
        log_success "System memory: $((total_ram_mb / 1024))GB RAM (Recommended >= 2GB)"
    fi
    
    # 5. Internet Connection
    run_with_spinner "Checking internet connection" curl -sI --connect-timeout 5 "https://launchermeta.mojang.com"
    if [ $? -ne 0 ]; then
        log_error "No active internet connection or Mojang services are unreachable."
        draw_box_close
        exit 1
    fi
    
    draw_box_close
}

# --- Java Management Functions ---
get_java_installed_version() {
    if ! command -v java &>/dev/null; then
        echo 0
        return
    fi
    local raw_ver
    raw_ver=$(java -version 2>&1 | head -n 1 | awk -F '"' '{print $2}')
    if [[ "$raw_ver" == 1.* ]]; then
        echo "$raw_ver" | cut -d. -f2
    else
        echo "$raw_ver" | cut -d. -f1 | cut -d- -f1
    fi
}

get_required_java_version() {
    local mc_ver="$1"
    
    if [ "$mc_ver" = "latest" ]; then
        echo 21
        return
    fi
    
    local pkg_url
    pkg_url=$(curl -s "https://launchermeta.mojang.com/mc/game/version_manifest_v2.json" | jq -r --arg ver "$mc_ver" '.versions[] | select(.id == $ver) | .url' 2>/dev/null)
    if [ -n "$pkg_url" ] && [ "$pkg_url" != "null" ]; then
        local maj_ver
        maj_ver=$(curl -s "$pkg_url" | jq -r '.javaVersion.majorVersion' 2>/dev/null)
        if [[ "$maj_ver" =~ ^[0-9]+$ ]]; then
            echo "$maj_ver"
            return
        fi
    fi
    
    if [[ "$mc_ver" =~ ^2[56789]\. ]]; then
        echo 25
    elif [[ "$mc_ver" =~ ^1\.20\.[5-9] || "$mc_ver" =~ ^1\.21 ]]; then
        echo 21
    elif [[ "$mc_ver" =~ ^1\.17 || "$mc_ver" =~ ^1\.18 || "$mc_ver" =~ ^1\.19 || "$mc_ver" =~ ^1\.20 ]]; then
        echo 17
    else
        echo 8
    fi
}

find_java_binary_path() {
    local version="$1"
    
    local paths
    paths=$(ls -d /usr/lib/jvm/java-${version}-openjdk* 2>/dev/null)
    for p in $paths; do
        if [ -x "${p}/bin/java" ]; then
            echo "${p}/bin/java"
            return
        fi
    done
    
    local alt_path
    alt_path=$(update-alternatives --display java 2>/dev/null | grep -E "priority|link" | grep -oE "/usr/lib/jvm/[^ ]+/bin/java" | grep "java-${version}" | head -n 1)
    if [ -n "$alt_path" ] && [ -x "$alt_path" ]; then
        echo "$alt_path"
        return
    fi
    
    local current_ver
    current_ver=$(get_java_installed_version)
    if [ "$current_ver" -eq "$version" ]; then
        echo "java"
        return
    fi
    
    echo "java"
}

install_java_package() {
    local version="$1"
    local pkg_name="openjdk-${version}-jdk"
    
    log_info "Installing Java $version ($pkg_name)..."
    
    if [ "$EUID" -ne 0 ] && ! command -v sudo &>/dev/null; then
        log_error "Root permissions or sudo required to install Java."
        return 1
    fi
    
    local pkg_avail=false
    if apt-cache show "$pkg_name" &>/dev/null; then
        pkg_avail=true
    fi
    
    if [ "$pkg_avail" = "false" ]; then
        log_warn "Package $pkg_name not found in default repositories."
        if [ -f /etc/os-release ] && grep -q -i "ubuntu" /etc/os-release; then
            log_info "Adding PPA ppa:openjdk-r/ppa for Ubuntu..."
            local ppa_cmd="apt-get install -y software-properties-common && add-apt-repository -y ppa:openjdk-r/ppa && apt-get update"
            if [ "$EUID" -eq 0 ]; then
                run_with_spinner "Adding PPA" bash -c "$ppa_cmd"
            else
                run_with_spinner "Adding PPA (via sudo)" sudo bash -c "$ppa_cmd"
            fi
        fi
    fi
    
    local install_cmd="apt-get update && apt-get install -y $pkg_name"
    if [ "$EUID" -eq 0 ]; then
        run_with_spinner "Installing OpenJDK $version" bash -c "$install_cmd"
    else
        run_with_spinner "Installing OpenJDK $version (via sudo)" sudo bash -c "$install_cmd"
    fi
    return $?
}

verify_or_install_java() {
    local required_ver="$1"
    local installed_ver
    installed_ver=$(get_java_installed_version)
    
    if [ "$installed_ver" -ge "$required_ver" ]; then
        log_success "Java check passed: Java $installed_ver is installed (Requires >= $required_ver)"
        return 0
    fi
    
    log_warn "Required Java version >= $required_ver, but found Java $installed_ver (or missing)."
    if [[ "$OSTYPE" == "darwin"* ]]; then
        log_error "Please download and install Java $required_ver manually on macOS."
        return 1
    fi
    
    echo -n "  Would you like to install OpenJDK $required_ver automatically? [Y/n]: "
    read -r choice
    if [[ "$choice" =~ ^[Nn] ]]; then
        log_error "Cannot proceed without appropriate Java installation."
        return 1
    fi
    
    install_java_package "$required_ver"
    return $?
}

