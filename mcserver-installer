is_port_taken_by_registered_servers() {
    local check_port="$1"
    if [ -f "$REGISTRY_FILE" ]; then
        while IFS=: read -r r_name r_path r_type r_ver || [ -n "$r_name" ]; do
            [ -z "$r_name" ] && continue
            local reg_port
            reg_port=$(get_server_port "$r_path" "$r_type")
            if [ "$reg_port" = "$check_port" ]; then
                return 0
            fi
        done < "$REGISTRY_FILE"
    fi
    return 1
}

get_server_port() {
    local s_path="$1"
    local s_type="$2"
    local port=""
    if [ -f "${s_path}/server.properties" ]; then
        port=$(grep "^server-port=" "${s_path}/server.properties" | cut -d= -f2- | tr -d '\r')
    elif [ -f "${s_path}/velocity.toml" ]; then
        port=$(grep "bind =" "${s_path}/velocity.toml" | head -n 1 | cut -d: -f2 | tr -d '"\r ' | cut -d']' -f1)
    elif [ -f "${s_path}/config.yml" ]; then
        port=$(grep -A 5 "listeners:" "${s_path}/config.yml" 2>/dev/null | grep "host:" | head -n 1 | cut -d: -f3 | tr -d '\r ')
    fi
    
    # Default fallbacks
    if [ -z "$port" ]; then
        if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
            echo "25577"
        else
            echo "25565"
        fi
    else
        echo "$port"
    fi
}

get_local_ip() {
    if command -v hostname &>/dev/null; then
        hostname -I | awk '{print $1}' | tr -d '\r\n '
    elif command -v ip &>/dev/null; then
        ip route get 1.1.1.1 2>/dev/null | awk '{print $7}' | tr -d '\r\n '
    else
        ifconfig 2>/dev/null | grep -E "inet " | grep -v 127.0.0.1 | awk '{print $2}' | head -n 1 | tr -d '\r\n '
    fi
}

toggle_systemd_service() {
    local s_name="$1"
    local s_path="$2"
    local session_name
    session_name=$(get_session_name "$s_path")
    
    local service_file="/etc/systemd/system/mc-${session_name}.service"
    local active_str="Disabled"
    if [ -f "$service_file" ]; then
        active_str="Enabled"
    fi
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}SYSTEMD BOOT AUTO-START CONTROLLER${COLOR_RESET}"
    echo -e "  Server: $s_name | Auto-start status: ${COLOR_YELLOW}${active_str}${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    if [ "$active_str" = "Enabled" ]; then
        prompt_yes_no "Do you want to disable boot auto-start for this server?" "n"
        if [ $? -eq 0 ]; then
            local disable_cmd="systemctl stop mc-${session_name} && systemctl disable mc-${session_name} && rm -f $service_file && systemctl daemon-reload"
            if [ "$EUID" -eq 0 ]; then
                run_with_spinner "Disabling systemd service" bash -c "$disable_cmd"
            else
                run_with_spinner "Disabling systemd service (via sudo)" sudo bash -c "$disable_cmd"
            fi
            log_success "Boot auto-start disabled successfully."
        fi
    else
        prompt_yes_no "Do you want to enable boot auto-start for this server?" "y"
        if [ $? -eq 0 ]; then
            local tmp_service
            tmp_service=$(mktemp)
            cat > "$tmp_service" <<EOF
[Unit]
Description=Minecraft Server - ${s_name}
After=network.target

[Service]
Type=forking
User=${USER}
WorkingDirectory=${s_path}
ExecStart=/usr/bin/screen -dmS ${session_name} ./start.sh
ExecStop=/bin/bash -c "/usr/bin/screen -S ${session_name} -p 0 -X stuff 'stop\r'"
TimeoutStopSec=30
Restart=on-failure

[Install]
WantedBy=multi-user.target
EOF
            
            local enable_cmd="cp $tmp_service $service_file && chown root:root $service_file && chmod 644 $service_file && systemctl daemon-reload && systemctl enable mc-${session_name}"
            if [ "$EUID" -eq 0 ]; then
                run_with_spinner "Enabling systemd service" bash -c "$enable_cmd"
            else
                run_with_spinner "Enabling systemd service (via sudo)" sudo bash -c "$enable_cmd"
            fi
            rm -f "$tmp_service"
            log_success "Boot auto-start enabled successfully!"
        fi
    fi
    sleep 2
}

get_java_pid_for_session() {
    local session_name="$1"
    
    local screen_pid
    screen_pid=$(screen -ls | grep "\.${session_name}" | head -n 1 | awk '{print $1}' | cut -d. -f1 | tr -d '\r\n')
    if [ -z "$screen_pid" ]; then
        return 1
    fi
    
    local java_pids
    java_pids=$(pgrep -x java || pgrep -f java || true)
    if [ -z "$java_pids" ]; then
        return 1
    fi
    
    for pid in $java_pids; do
        local curr=$pid
        while [ "$curr" -gt 1 ]; do
            local ppid
            ppid=$(ps -o ppid= -p "$curr" 2>/dev/null | tr -d ' ' | tr -d '\r\n')
            if [ -z "$ppid" ] || [ "$ppid" -le 1 ]; then
                break
            fi
            if [ "$ppid" -eq "$screen_pid" ]; then
                echo "$pid"
                return 0
            fi
            curr=$ppid
        done
    done
    return 1
}

monitor_server_resources() {
    local s_name="$1"
    local s_path="$2"
    local session_name
    session_name=$(get_session_name "$s_path")
    
    if ! is_server_running "$session_name"; then
        log_error "Server is not running. Start it first to monitor resources!"
        sleep 2
        return 1
    fi
    
    local max_ram="Unknown"
    if [ -f "${s_path}/start.sh" ]; then
        max_ram=$(grep "^MEM_MAX=" "${s_path}/start.sh" | cut -d= -f2- | tr -d '"\r ')
    fi
    
    clear_screen
    while true; do
        local pid
        pid=$(get_java_pid_for_session "$session_name")
        if [ -z "$pid" ]; then
            echo -e "  Server process not found (stopped?)." >&2
            sleep 2
            break
        fi
        
        local cpu
        cpu=$(ps -p "$pid" -o %cpu= 2>/dev/null | tr -d ' ' | tr -d '\r\n')
        local rss
        rss=$(ps -p "$pid" -o rss= 2>/dev/null | tr -d ' ' | tr -d '\r\n')
        local disk
        disk=$(du -sh "$s_path" 2>/dev/null | awk '{print $1}' | tr -d '\r\n')
        
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}REAL-TIME RESOURCE MONITOR${COLOR_RESET}"
        echo -e "  Server: $s_name | Session: $session_name | PID: $pid"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
        
        if [ -n "$cpu" ]; then
            echo -e "  CPU Usage:      ${COLOR_YELLOW}${cpu}%${COLOR_RESET}"
        else
            echo -e "  CPU Usage:      Unknown"
        fi
        
        if [ -n "$rss" ] && [[ "$rss" =~ ^[0-9]+$ ]]; then
            local rss_mb=$((rss / 1024))
            local max_mb=0
            if [[ "$max_ram" =~ ^[0-9]+[GMgm]$ ]]; then
                local num
                num=$(echo "$max_ram" | tr -d 'GMgm')
                local unit
                unit=$(echo "$max_ram" | grep -oE "[GMgm]" | tr -d '\r\n')
                if [[ "$unit" =~ [Gg] ]]; then
                    max_mb=$((num * 1024))
                else
                    max_mb=$num
                fi
            fi
            
            if [ "$max_mb" -gt 0 ]; then
                local pct=$((rss_mb * 100 / max_mb))
                [ "$pct" -gt 100 ] && pct=100
                local filled=$((pct / 10))
                local empty=$((10 - filled))
                local bar=""
                for ((k=0; k<filled; k++)); do bar="${bar}█"; done
                for ((k=0; k<empty; k++)); do bar="${bar}░"; done
                echo -e "  RAM Usage:      ${COLOR_GREEN}[${bar}]${COLOR_RESET} ${rss_mb} MB / ${max_mb} MB (${pct}%)"
            else
                echo -e "  RAM Usage:      ${COLOR_GREEN}${rss_mb} MB${COLOR_RESET} / ${max_ram}"
            fi
        else
            echo -e "  RAM Usage:      Unknown"
        fi
        
        echo -e "  Disk Footprint: ${COLOR_BLUE}${disk}${COLOR_RESET}"
        echo -e "\n  Press 'q' and enter to return to the management menu."
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        
        local input_char=""
        read -t 2 -r input_char
        input_char=$(echo "$input_char" | tr -d '\r')
        if [ "$input_char" = "q" ] || [ "$input_char" = "Q" ]; then
            break
        fi
    done
}

