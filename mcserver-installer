    local inst_dir
    if [ "$LANG_PREF" = "tr" ]; then
        inst_dir=$(prompt_input "Kurulum dizinini girin" "$default_dir")
    else
        inst_dir=$(prompt_input "Enter installation directory" "$default_dir")
    fi
    
    # Expand tilde if present
    inst_dir="${inst_dir/#\~/$HOME}"
    
    # Resolve relative paths to absolute path
    if [[ "$inst_dir" != /* ]]; then
        inst_dir="$(pwd)/${inst_dir}"
    fi
    
    if [ -d "$inst_dir" ] && [ "$(ls -A "$inst_dir" 2>/dev/null)" ]; then
        log_warn "Directory $inst_dir exists and is NOT empty."
        prompt_yes_no "Do you want to overwrite files in this directory?" "n"
        if [ $? -ne 0 ]; then
            log_error "Installation canceled."
            exit 1
        fi
    fi
    
    # 5. RAM Selection
    local min_ram
    local max_ram
    min_ram=$(prompt_input "Enter Minimum RAM allocation (e.g., 1024M, 2G)" "1024M")
    max_ram=$(prompt_input "Enter Maximum RAM allocation (e.g., 4096M, 4G)" "4096M")
    
    # 6. Java Detection & Required Java configuration
    local required_java
    required_java=$(get_required_java_version "$mc_version")
    
    verify_or_install_java "$required_java"
    if [ $? -ne 0 ]; then
        log_error "Java setup failed. Cannot continue."
        exit 1
    fi
    
    local java_path
    java_path=$(find_java_binary_path "$required_java")

    
    # 7. Port check
    local default_port="25565"
    if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
        default_port="25577"
    fi
    
    local port
    while true; do
        if [ "$LANG_PREF" = "tr" ]; then
            port=$(prompt_input "Sunucu portunu girin" "$default_port")
        else
            port=$(prompt_input "Enter server port" "$default_port")
        fi
        
        # Check active port binding
        if command -v ss &>/dev/null; then
            if ss -tuln | grep -q ":${port} "; then
                if [ "$LANG_PREF" = "tr" ]; then
                    log_warn "Port $port şu anda kullanımda. Lütfen başka bir port seçin."
                else
                    log_warn "Port $port is currently in use. Please select a different port."
                fi
                continue
            fi
        fi
        
        # Check registered servers' ports
        if is_port_taken_by_registered_servers "$port"; then
            if [ "$LANG_PREF" = "tr" ]; then
                log_warn "Port $port zaten kayıtlı başka bir sunucu tarafından kullanılıyor. Lütfen başka bir port seçin."
            else
                log_warn "Port $port is already allocated to another registered server. Please select a different port."
            fi
            continue
        fi
        break
    done
    
    # Check if proxy type to skip gameplay questions
    local online_mode="true"
    local motd="A Minecraft Server"
    local max_players="20"
    local difficulty="normal"
    local gamemode="survival"
    local world_name="world"
    
    if [ "$s_type" != "velocity" ] && [ "$s_type" != "waterfall" ] && [ "$s_type" != "bungeecord" ]; then
        # 8. Online Mode
        online_mode="true"
        prompt_yes_no "Enable Online Mode (authenticate accounts via Mojang)?" "y"
        [ $? -ne 0 ] && online_mode="false"
        
        # 9. MOTD
        motd=$(prompt_input "Enter Server MOTD" "Welcome to our devRaikou Server!")
        
        # 10. Max Players
        max_players=$(prompt_input "Enter Max Players" "20")
        
        # 11. Difficulty
        difficulty=$(prompt_selection "Select Difficulty:" peaceful easy normal hard)
        
        # 12. GameMode
        gamemode=$(prompt_selection "Select Default GameMode:" survival creative adventure spectator)
        
        # 13. World Name
        world_name=$(prompt_input "Enter World Name" "world")
    fi
    
    # 14. EULA acceptance check
    prompt_yes_no "Do you agree to Mojang's EULA (https://account.mojang.com/documents/minecraft_eula)?" "y"
    if [ $? -ne 0 ]; then
        log_error "You must agree to the EULA to install the server."
        exit 1
    fi
    
    # --- Perform Installation Actions ---
    mkdir -p "$inst_dir"
    cd "$inst_dir" || { log_error "Failed to enter installation folder."; exit 1; }
    
    # Download the main jar/installer file
    local jar_dest="server.jar"
    if [ "$s_type" = "fabric" ] || [ "$s_type" = "forge" ] || [ "$s_type" = "neoforge" ]; then
        jar_dest="installer.jar"
    fi
    
    download_file_with_progress "$download_url" "$jar_dest" "$s_type jar"
    if [ $? -ne 0 ]; then
        log_error "Failed to download server file."
        exit 1
    fi
    
    # If Modded installer, run installServer
    local final_jar="server.jar"
    if [ "$s_type" = "fabric" ]; then
        run_with_spinner "Extracting Fabric server resources" java -jar installer.jar server -mcversion "$mc_version" -loader "$loader_version" -downloadMinecraft
        if [ $? -ne 0 ]; then
            log_error "Fabric server installation failed."
            exit 1
        fi
        final_jar="fabric-server-launch.jar"
        rm -f installer.jar
    elif [ "$s_type" = "forge" ]; then
        run_with_spinner "Installing Forge server dependencies (may take a few minutes)" java -jar installer.jar --installServer
        if [ $? -ne 0 ]; then
            log_error "Forge server installation failed."
            exit 1
        fi
        # Locate forge run script or jar
        if [ -f run.sh ]; then
            # Modern Forge (1.17+) does not run jar directly, it uses a generated run.sh
            final_jar="FORGE_RUN_SCRIPT"
        else
            # Older Forge uses forge-<version>.jar
            final_jar=$(ls forge-*.jar | head -n 1)
        fi
        rm -f installer.jar installer.jar.log
    elif [ "$s_type" = "neoforge" ]; then
        run_with_spinner "Installing NeoForge server dependencies (may take a few minutes)" java -jar installer.jar --installServer
        if [ $? -ne 0 ]; then
            log_error "NeoForge server installation failed."
            exit 1
        fi
        final_jar="NEOFORGE_RUN_SCRIPT"
        rm -f installer.jar installer.jar.log
    elif [ "$s_type" = "velocity" ]; then
        final_jar="velocity.jar"
        mv server.jar velocity.jar
    elif [ "$s_type" = "waterfall" ]; then
        final_jar="waterfall.jar"
        mv server.jar waterfall.jar
    fi
    
    # Save EULA
    echo "eula=true" > eula.txt
    
    # Save properties (if not proxy)
    if [ "$s_type" != "velocity" ] && [ "$s_type" != "waterfall" ] && [ "$s_type" != "bungeecord" ]; then
        echo "# Generated by mcserver-installer" > server.properties
        echo "server-port=$port" >> server.properties
        echo "online-mode=$online_mode" >> server.properties
        echo "motd=$motd" >> server.properties
        echo "max-players=$max_players" >> server.properties
        echo "difficulty=$difficulty" >> server.properties
        echo "gamemode=$gamemode" >> server.properties
        echo "level-name=$world_name" >> server.properties
    fi
    
    # Ask for Aikar Flags
    local include_aikar="false"
    prompt_yes_no "Enable Aikar's optimized Garbage Collection Flags for JVM?" "y"
    [ $? -eq 0 ] && include_aikar="true"
    
    local jvm_args=""
    if [ "$include_aikar" = "true" ]; then
        jvm_args="-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8M -XX:G1ReservePercent=20 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1MixedGCCountTarget=4 -XX:G1HeapWastePercent=5 -XX:SurvivorRatio=32 -XX:MaxTenuringThreshold=1 -Dusing.aikars.flags=https://mcflags.emc.gs -Daikars.new.flags=true"
    fi
    
    # Create start.sh script
    local java_dir
    java_dir=$(dirname "$java_path")
    local path_inject=""
    if [ "$java_dir" != "." ] && [ "$java_dir" != "/usr/bin" ] && [ "$java_dir" != "/bin" ]; then
        path_inject="export PATH=\"${java_dir}:\$PATH\""
    fi

    cat > start.sh <<EOF
#!/usr/bin/env bash
# Generated by mcserver-installer (${DEVELOPER})
# Minecraft Server Auto-Restart script

${path_inject}

MEM_MIN="${min_ram}"
MEM_MAX="${max_ram}"

cd "\$(dirname "\$0")"

while [ ! -f .stop_restart ]; do
    echo "[mcserver-installer] Starting Minecraft server..."
EOF

    if [ "$final_jar" = "FORGE_RUN_SCRIPT" ] || [ "$final_jar" = "NEOFORGE_RUN_SCRIPT" ]; then
        # Modern Forge/NeoForge uses run.sh to launch, configure variables there
        # We edit user_jvm_args.txt to inject memory size and parameters
        if [ -f user_jvm_args.txt ]; then
            echo "-Xms${min_ram}" > user_jvm_args.txt
            echo "-Xmx${max_ram}" >> user_jvm_args.txt
            if [ -n "$jvm_args" ]; then
                echo "$jvm_args" >> user_jvm_args.txt
            fi
        fi
        echo "    bash run.sh nogui" >> start.sh
    else
        echo "    java -Xms\"\${MEM_MIN}\" -Xmx\"\${MEM_MAX}\" ${jvm_args} -jar ${final_jar} nogui" >> start.sh
    fi
    
    cat >> start.sh <<EOF
    if [ -f .stop_restart ]; then
        break
    fi
    echo "[mcserver-installer] Server stopped. Restarting in 5 seconds (Press Ctrl+C to cancel)..."
    sleep 5
done
rm -f .stop_restart
EOF

    chmod +x start.sh
    
    # Save details into local registry file
    local server_name
    server_name=$(basename "$inst_dir")
    # Clean duplicates in registry if path already exists
    if [ -f "$REGISTRY_FILE" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^.*:$inst_dir:.*$||" "$REGISTRY_FILE"
        else
            sed -i "s|^.*:$inst_dir:.*$||" "$REGISTRY_FILE"
        fi
        # Remove empty lines
        sed -i '/^[[:space:]]*$/d' "$REGISTRY_FILE"
    fi
    echo "${server_name}:${inst_dir}:${s_type}:${mc_version}" >> "$REGISTRY_FILE"
    
    # Run backend orchestrator if proxy server software was installed
    if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
        orchestrate_proxy_network "$inst_dir" "$server_name" "$s_type" "$port"
    fi
    
    echo -e "\n"
    draw_box_open "Installation Complete!"
    log_success "Server type: $s_type ($mc_version) installed successfully."
    log_success "Path: $inst_dir"
    log_success "Executable: ./start.sh"
    log_info "You can now start and manage this server from the main menu!"
    draw_box_close
    
    echo -e -n "\n  Press [Enter] to return to the main menu: "
    read -r _
}

# --- Properties Editor ---
get_property_val() {
    local file="$1"
    local key="$2"
    grep "^${key}=" "$file" | cut -d= -f2-
}

set_property_val() {
    local file="$1"
    local key="$2"
    local val="$3"
    if grep -q "^${key}=" "$file"; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^${key}=.*|${key}=${val}|" "$file"
        else
            sed -i "s|^${key}=.*|${key}=${val}|" "$file"
        fi
    else
        echo "${key}=${val}" >> "$file"
    fi
}

