select_and_manage_server() {
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        log_warn "No installed servers registered."
        sleep 2
        return 1
    fi
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}SELECT INSTALLED SERVER${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    # Read registry
    local servers=()
    local paths=()
    local types=()
    local versions=()
    local list_options=()
    
    local i=1
    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        # Skip empty lines
        [ -z "$name" ] && continue
        
        servers+=("$name")
        paths+=("$path")
        types+=("$type")
        versions+=("$version")
        
        # Check active status
        local sess; sess=$(get_session_name "$path")
        local status="${COLOR_RED}[Stopped]${COLOR_RESET}"
        if is_server_running "$sess"; then
            status="${COLOR_GREEN}[Running]${COLOR_RESET}"
        fi
        
        list_options+=("$name ($type $version) - $path $status")
        i=$((i + 1))
    done < "$REGISTRY_FILE"
    
    if [ ${#servers[@]} -eq 0 ]; then
        log_warn "No valid servers registered in the registry."
        sleep 2
        return 1
    fi
    
    list_options+=("Return to Main Menu")
    local selection
    selection=$(prompt_selection "Choose server to manage:" "${list_options[@]}")
    
    if [ "$selection" = "Return to Main Menu" ]; then
        return 0
    fi
    
    # Find matching index
    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done
    
    if [ "$idx" -ne -1 ]; then
        run_server_management_menu "${servers[$idx]}" "${paths[$idx]}" "${types[$idx]}" "${versions[$idx]}"
    fi
}

