        echo -e "    ${COLOR_YELLOW}9.${COLOR_RESET} Allow Flight      [${COLOR_GREEN}${flight}${COLOR_RESET}]"
        echo -e "   ${COLOR_YELLOW}10.${COLOR_RESET} Spawn Protection  [${COLOR_GREEN}${spawn_prot}${COLOR_RESET}]"
        echo -e "   ${COLOR_YELLOW}11.${COLOR_RESET} Return to Management Menu"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        
