# --- Backup & Restore Subsystem ---
create_server_backup() {
    local server_path="$1"
    local backup_dir="${server_path}/backups"
    mkdir -p "$backup_dir"
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}BACKUP CREATION${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local tar_name="backup_${timestamp}.tar.gz"
    local tar_path="${backup_dir}/${tar_name}"
    
    log_info "Creating backup archive in progress..."
    
    # Archive files, excluding logs and backups folder
    # We do cd server_path so we archive relative paths
    (cd "$server_path" && tar --exclude='./backups' --exclude='./logs' -czf "$tar_path" .)
    local status=$?
    
    if [ $status -eq 0 ]; then
        local size_bytes
        if [[ "$OSTYPE" == "darwin"* ]]; then
            size_bytes=$(stat -f %z "$tar_path")
        else
            size_bytes=$(stat -c %s "$tar_path")
        fi
        local size_mb=$((size_bytes / 1024 / 1024))
        log_success "Backup completed successfully!"
        log_success "Saved as: backups/${tar_name} (${size_mb} MB)"
    else
        log_error "Backup compression failed."
    fi
    
    echo -e -n "\n  Press [Enter] to return: "
    read -r _
}

run_server_restore() {
    local server_path="$1"
    local backup_dir="${server_path}/backups"
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}RESTORE BACKUP${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    if [ ! -d "$backup_dir" ] || [ -z "$(ls -A "$backup_dir" 2>/dev/null)" ]; then
        log_warn "No backups found for this server."
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 1
    fi
    
    local backups_list=()
    for f in "$backup_dir"/backup_*.tar.gz; do
        if [ -f "$f" ]; then
            backups_list+=("$(basename "$f")")
        fi
    done
    
    if [ ${#backups_list[@]} -eq 0 ]; then
        log_warn "No valid backups found."
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 1
    fi
    
    # Sort backups in descending order (newest first)
    IFS=$'\n' sorted_backups=($(sort -r <<<"${backups_list[*]}"))
    unset IFS
    
    local chosen_backup
    chosen_backup=$(prompt_selection "Select backup to restore:" "${sorted_backups[@]}")
    local full_backup_path="${backup_dir}/${chosen_backup}"
    
    log_warn "RESTORE ACTION IS DESTRUCTIVE!"
    log_warn "This will overwrite your existing world files, properties, and configurations."
    prompt_yes_no "Are you absolutely sure you want to restore ${chosen_backup}?" "n"
    if [ $? -ne 0 ]; then
        log_info "Restore canceled."
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 0
    fi
    
    # We remove worlds and configs but keep logs and backup folder safe
    log_info "Clearing directory for restore..."
    find "$server_path" -maxdepth 1 -not -name "backups" -not -name "logs" -not -name "." -not -name ".." -exec rm -rf {} +
    
    log_info "Extracting backup content..."
    tar -xzf "$full_backup_path" -C "$server_path"
    local status=$?
    
    if [ $status -eq 0 ]; then
        log_success "Backup restored successfully!"
        log_info "Please verify the start script and java configurations before starting."
    else
        log_error "Failed to extract backup file correctly."
    fi
    
    echo -e -n "\n  Press [Enter] to return: "
    read -r _
}

# --- Server Lifecycle & Console Manager ---

get_session_name() {
    local s_path="$1"
    local hash
    if command -v md5sum &>/dev/null; then
        hash=$(echo -n "$s_path" | md5sum | cut -c1-8)
    else
        hash=$(echo -n "$s_path" | md5 | cut -c1-8)
    fi
    local name
    name=$(basename "$s_path" | tr -cd 'a-zA-Z0-9_-')
    echo "mc-${name}-${hash}"
}

is_server_running() {
    local session_name="$1"
    screen -list | grep -q "\.${session_name}"
}

start_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if is_server_running "$session_name"; then
        log_warn "Server is already running in screen session: $session_name"
        sleep 2
        return 1
    fi
    
    log_info "Starting server..."
    # Ensure any residual stop files are gone
    rm -f "${server_path}/.stop_restart"
    
    (cd "$server_path" && screen -dmS "$session_name" ./start.sh)
    
    # Wait and check status
    sleep 2
    if is_server_running "$session_name"; then
        log_success "Server started successfully in background!"
        log_info "Screen session: $session_name"
    else
        log_error "Server failed to start. Check your logs/latest.log or start.sh."
    fi
    sleep 2
}

stop_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if ! is_server_running "$session_name"; then
        log_warn "Server is not running."
        sleep 2
        return 1
    fi
    
    log_info "Sending stop command to server..."
    # Write stop file so the start.sh restart loop breaks
    touch "${server_path}/.stop_restart"
    
    # Send "stop" command to the screen console input
    screen -S "$session_name" -p 0 -X stuff "stop$(printf \\r)"
    
    # Wait loop
    local count=0
    printf "  Waiting for server to stop gracefully "
    while is_server_running "$session_name" && [ $count -lt 30 ]; do
        printf "."
        sleep 1
        count=$((count + 1))
    done
    printf "\n"
    
    if is_server_running "$session_name"; then
        log_warn "Server did not stop gracefully. Forcing termination..."
        screen -S "$session_name" -p 0 -X quit
        # Kill any remaining java processes started under the screen directory
        pkill -f "java.*${session_name}"
    else
        log_success "Server stopped gracefully."
    fi
    rm -f "${server_path}/.stop_restart"
    sleep 2
}

restart_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if is_server_running "$session_name"; then
        stop_minecraft_server "$server_path"
    fi
    start_minecraft_server "$server_path"
}

view_server_logs() {
    local server_path="$1"
    local log_file="${server_path}/logs/latest.log"
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}SERVER LOG VIEWER${COLOR_RESET} (Press Ctrl+C to exit)"
    echo -e "  File: $log_file"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    if [ ! -f "$log_file" ]; then
        log_error "Log file not found yet. Has the server run at least once?"
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
        return 1
    fi
    
    # Tail logs
    tail -n 100 -f "$log_file"
}

connect_server_console() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")
    
    if ! is_server_running "$session_name"; then
        log_error "Server is not running. Start the server first!"
        sleep 2
        return 1
    fi
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}CONNECTING TO SERVER CONSOLE${COLOR_RESET}"
    echo -e "  ${COLOR_YELLOW}IMPORTANT: To detach from the console without stopping the server,${COLOR_RESET}"
    echo -e "  ${COLOR_YELLOW}Press: Ctrl+A, then D${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    echo -e "  Connecting in 3 seconds..."
    sleep 3
    
    screen -r "$session_name"
}

# --- Management Menu for a Specific Server ---
run_server_management_menu() {
    local s_name="$1"
    local s_path="$2"
    local s_type="$3"
    local s_ver="$4"
    
    while true; do
        local session_name
        session_name=$(get_session_name "$s_path")
        local status_str="${COLOR_RED}Stopped${COLOR_RESET}"
        if is_server_running "$session_name"; then
            status_str="${COLOR_GREEN}Running${COLOR_RESET}"
        fi
        
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}MANAGE SERVER: $s_name${COLOR_RESET}"
        echo -e "  Path: $s_path"
        echo -e "  Software: $s_type ($s_ver) | Status: $status_str"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
        
        echo -e "    ${COLOR_YELLOW}1.${COLOR_RESET} Start Server"
        echo -e "    ${COLOR_YELLOW}2.${COLOR_RESET} Stop Server"
        echo -e "    ${COLOR_YELLOW}3.${COLOR_RESET} Restart Server"
        echo -e "    ${COLOR_YELLOW}4.${COLOR_RESET} Connect to Console"
        echo -e "    ${COLOR_YELLOW}5.${COLOR_RESET} View Server Logs"
        echo -e "    ${COLOR_YELLOW}6.${COLOR_RESET} Edit server.properties"
        echo -e "    ${COLOR_YELLOW}7.${COLOR_RESET} Create Backup"
        echo -e "    ${COLOR_YELLOW}8.${COLOR_RESET} Restore Backup"
        echo -e "    ${COLOR_YELLOW}9.${COLOR_RESET} Change Server Memory Allocation (RAM)"
        echo -e "   ${COLOR_YELLOW}10.${COLOR_RESET} Return to Main Menu"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        
        echo -n "  Select option (1-10): "
        read -r choice
        
        case "$choice" in
            1)
                start_minecraft_server "$s_path"
                ;;
            2)
                stop_minecraft_server "$s_path"
                ;;
            3)
                restart_minecraft_server "$s_path"
                ;;
            4)
                connect_server_console "$s_path"
                ;;
            5)
                view_server_logs "$s_path"
                ;;
            6)
                if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
                    log_warn "Proxy servers do not use standard server.properties files."
                    sleep 2
                else
                    run_properties_editor "$s_path"
                fi
                ;;
            7)
                create_server_backup "$s_path"
                ;;
            8)
                if is_server_running "$session_name"; then
                    log_error "Please stop the server before running a restore!"
                    sleep 2
                else
                    run_server_restore "$s_path"
                fi
                ;;
            9)
                if [ ! -f "${s_path}/start.sh" ]; then
                    log_error "No start.sh script found to modify memory values."
                    sleep 2
                else
                    clear_screen
                    draw_header
                    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}CHANGE MEMORY CONFIGURATION${COLOR_RESET}\n"
                    local min_ram; min_ram=$(prompt_input "Enter new Minimum RAM allocation" "1024M")
                    local max_ram; max_ram=$(prompt_input "Enter new Maximum RAM allocation" "4096M")
                    
                    # Update start.sh variables
                    if [[ "$OSTYPE" == "darwin"* ]]; then
                        sed -i '' "s|^MEM_MIN=.*|MEM_MIN=\"${min_ram}\"|" "${s_path}/start.sh"
                        sed -i '' "s|^MEM_MAX=.*|MEM_MAX=\"${max_ram}\"|" "${s_path}/start.sh"
                    else
                        sed -i "s|^MEM_MIN=.*|MEM_MIN=\"${min_ram}\"|" "${s_path}/start.sh"
                        sed -i "s|^MEM_MAX=.*|MEM_MAX=\"${max_ram}\"|" "${s_path}/start.sh"
                    fi
                    
                    # Check for forge user_jvm_args.txt
                    if [ -f "${s_path}/user_jvm_args.txt" ]; then
                        if [[ "$OSTYPE" == "darwin"* ]]; then
                            sed -i '' "s|-Xms.*|-Xms${min_ram}|" "${s_path}/user_jvm_args.txt"
                            sed -i '' "s|-Xmx.*|-Xmx${max_ram}|" "${s_path}/user_jvm_args.txt"
                        else
                            sed -i "s|-Xms.*|-Xms${min_ram}|" "${s_path}/user_jvm_args.txt"
                            sed -i "s|-Xmx.*|-Xmx${max_ram}|" "${s_path}/user_jvm_args.txt"
                        fi
                    fi
                    
                    log_success "Memory values updated successfully!"
                    sleep 2
                fi
                ;;
            10)
                break
                ;;
            *)
                log_warn "Invalid selection."
                sleep 1
                ;;
        esac
    done
}

select_and_manage_server() {
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        log_warn "No installed servers registered."
        sleep 2
        return 1
    fi
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}SELECT INSTALLED SERVER${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    # Read registry
    local servers=()
    local paths=()
    local types=()
    local versions=()
    local list_options=()
    
    local i=1
    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        # Skip empty lines
        [ -z "$name" ] && continue
        
        servers+=("$name")
        paths+=("$path")
        types+=("$type")
        versions+=("$version")
        
        # Check active status
        local sess; sess=$(get_session_name "$path")
        local status="${COLOR_RED}[Stopped]${COLOR_RESET}"
        if is_server_running "$sess"; then
            status="${COLOR_GREEN}[Running]${COLOR_RESET}"
        fi
        
        list_options+=("$name ($type $version) - $path $status")
        i=$((i + 1))
    done < "$REGISTRY_FILE"
    
    if [ ${#servers[@]} -eq 0 ]; then
        log_warn "No valid servers registered in the registry."
        sleep 2
        return 1
    fi
    
    list_options+=("Return to Main Menu")
    local selection
    selection=$(prompt_selection "Choose server to manage:" "${list_options[@]}")
    
    if [ "$selection" = "Return to Main Menu" ]; then
        return 0
    fi
    
    # Find matching index
    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done
    
    if [ "$idx" -ne -1 ]; then
        run_server_management_menu "${servers[$idx]}" "${paths[$idx]}" "${types[$idx]}" "${versions[$idx]}"
    fi
}

