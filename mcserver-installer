            log_info "Fetching builds for $s_type $mc_version..."
            local builds
            builds=$(fetch_papermc_builds "$s_type" "$mc_version" | sort -nr)
            
            if [ -z "$builds" ]; then
                log_error "No builds found for $s_type version $mc_version."
                exit 1
            fi
            
            local build_choices=()
            for b in $builds; do build_choices+=("$b"); done
            build_choices+=("Latest Stable")
            
            local chosen_build
            chosen_build=$(prompt_selection "Select build number:" "${build_choices[@]}")
            if [ "$chosen_build" = "Latest Stable" ]; then
                build_num=$(echo "${build_choices[0]}")
            else
                build_num="$chosen_build"
            fi
            
            log_info "Resolving download URL for $s_type $mc_version Build $build_num..."
            download_url=$(fetch_papermc_download_url "$s_type" "$mc_version" "$build_num")
            ;;
        purpur)
            log_info "Fetching Purpur versions..."
            local versions
            versions=$(fetch_purpur_versions)
            mc_version=$(prompt_selection "Select Minecraft version:" $versions)
            
            log_info "Fetching builds for Purpur $mc_version..."
            local builds
            builds=$(fetch_purpur_builds "$mc_version" | sort -nr)
            
            if [ -z "$builds" ]; then
                log_error "No builds found for Purpur version $mc_version."
                exit 1
            fi
            
            local build_choices=()
            for b in $builds; do build_choices+=("$b"); done
            build_choices+=("Latest Stable")
            
            local chosen_build
            chosen_build=$(prompt_selection "Select build number:" "${build_choices[@]}")
            if [ "$chosen_build" = "Latest Stable" ]; then
                build_num="latest"
            else
                build_num="$chosen_build"
            fi
            
            download_url="https://api.purpurmc.org/v2/purpur/$mc_version/$build_num/download"
            ;;
        fabric)
            log_info "Fetching Fabric game versions..."
            local releases
            releases=$(fetch_vanilla_releases)
            mc_version=$(prompt_selection "Select Minecraft version:" $releases)
            
            log_info "Fetching Fabric Loader versions..."
            local loaders
            loaders=$(fetch_fabric_loaders)
            loader_version=$(prompt_selection "Select Fabric Loader version:" $loaders)
            
            log_info "Resolving Fabric Installer URL..."
            download_url=$(fetch_fabric_installer_url)
            ;;
        forge)
            log_info "Fetching supported Minecraft versions for Forge..."
            local releases
            releases=(1.21.4 1.21.1 1.21 1.20.6 1.20.4 1.20.2 1.20.1 1.20 1.19.4 1.19.2 1.18.2 1.17.1 1.16.5 1.12.2 1.8.8 1.7.10)
            mc_version=$(prompt_selection "Select Minecraft version:" "${releases[@]}")
            
            log_info "Fetching Forge builds for $mc_version..."
            local builds
            builds=$(fetch_forge_versions "$mc_version")
            
            if [ -z "$builds" ]; then
                log_error "No Forge builds found for Minecraft $mc_version."
                exit 1
            fi
            
            local chosen_build
            chosen_build=$(prompt_selection "Select Forge build:" $builds)
            download_url="https://maven.minecraftforge.net/net/minecraftforge/forge/${chosen_build}/forge-${chosen_build}-installer.jar"
            ;;
        neoforge)
            log_info "Fetching supported Minecraft versions for NeoForge..."
            local releases=(1.21.4 1.21.3 1.21.1 1.21 1.20.6 1.20.4 1.20.2 1.20.1)
            mc_version=$(prompt_selection "Select Minecraft version:" "${releases[@]}")
            
            log_info "Fetching NeoForge builds for $mc_version..."
            local builds
            builds=$(fetch_neoforge_versions "$mc_version")
            
            if [ -z "$builds" ]; then
                log_error "No NeoForge builds found for Minecraft $mc_version."
                exit 1
            fi
            
            local chosen_build
            chosen_build=$(prompt_selection "Select NeoForge build:" $builds)
            download_url="https://maven.neoforged.net/releases/net/neoforged/neoforge/${chosen_build}/neoforge-${chosen_build}-installer.jar"
            ;;
