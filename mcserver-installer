remove_server_registration() {
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        if [ "$LANG_PREF" = "tr" ]; then
            log_warn "Kayıtlı kurulu sunucu bulunamadı."
        else
            log_warn "No installed servers registered."
        fi
        sleep 2
        return 1
    fi

    clear_screen
    draw_header
    if [ "$LANG_PREF" = "tr" ]; then
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}SUNUCUYU SİL / KAYDI SİL${COLOR_RESET}"
    else
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}DELETE SERVER / REGISTRATION${COLOR_RESET}"
    fi
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    local servers=()
    local paths=()
    local list_options=()

    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        [ -z "$name" ] && continue
        servers+=("$name")
        paths+=("$path")
        list_options+=("$name - $path")
    done < "$REGISTRY_FILE"

    if [ "$LANG_PREF" = "tr" ]; then
        list_options+=("TÜM SUNUCULARI SİL")
        list_options+=("İptal Et ve Çık")
    else
        list_options+=("DELETE ALL SERVERS")
        list_options+=("Cancel and Exit")
    fi

    local selection
    if [ "$LANG_PREF" = "tr" ]; then
        selection=$(prompt_selection "Silmek istediğiniz sunucuyu seçin:" "${list_options[@]}")
    else
        selection=$(prompt_selection "$(t "prompt_delete_server" "Choose server to delete:")" "${list_options[@]}")
    fi

    if [ "$selection" = "Cancel and Exit" ] || [ "$selection" = "İptal Et ve Çık" ]; then
        return 0
    fi

    if [ "$selection" = "DELETE ALL SERVERS" ] || [ "$selection" = "TÜM SUNUCULARI SİL" ]; then
        for k in "${!paths[@]}"; do
            local path="${paths[$k]}"
            local sess_name; sess_name=$(get_session_name "$path")
            if is_server_running "$sess_name"; then
                if [ "$LANG_PREF" = "tr" ]; then
                    log_info "Çalışan sunucu kapatılıyor: ${servers[$k]}..."
                else
                    log_info "Stopping running server: ${servers[$k]}..."
                fi
                stop_minecraft_server "$path"
            fi
        done

        local delete_files="false"
        if [ "$LANG_PREF" = "tr" ]; then
            if prompt_yes_no "Tüm sunucuların dosyalarını tamamen silmek istiyor musunuz?" "n"; then
                delete_files="true"
            fi
        else
            if prompt_yes_no "Do you want to completely erase files for all servers?" "n"; then
                delete_files="true"
            fi
        fi

        for k in "${!paths[@]}"; do
            local path="${paths[$k]}"
            if [ "$delete_files" = "true" ]; then
                if [ "$LANG_PREF" = "tr" ]; then
                    run_with_spinner "Siliniyor: ${servers[$k]}" rm -rf "$path"
                else
                    run_with_spinner "Deleting: ${servers[$k]}" rm -rf "$path"
                fi
            fi
        done

        echo -n "" > "$REGISTRY_FILE"

        if [ "$LANG_PREF" = "tr" ]; then
            if [ "$delete_files" = "true" ]; then
                log_success "Tüm sunucular ve dosyaları başarıyla silindi."
            else
                log_success "Tüm sunucu kayıtları kaldırıldı, ancak dosyalar korundu."
            fi
        else
            if [ "$delete_files" = "true" ]; then
                log_success "All servers and files deleted successfully."
            else
                log_success "All server registrations removed, but files were kept."
            fi
        fi
        sleep 2
        return 0
    fi

    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done

    if [ "$idx" -eq -1 ]; then return 0; fi

    local sel_name="${servers[$idx]}"
    local sel_path="${paths[$idx]}"
    local sess_name; sess_name=$(get_session_name "$sel_path")

    if is_server_running "$sess_name"; then
        if [ "$LANG_PREF" = "tr" ]; then
            log_info "Çalışan sunucu kapatılıyor: ${sel_name}..."
        else
            log_info "Stopping running server: ${sel_name}..."
        fi
        stop_minecraft_server "$sel_path"
    fi

    local delete_files="false"
    if [ "$LANG_PREF" = "tr" ]; then
        if prompt_yes_no "${sel_path} dizinindeki tüm dosyaları tamamen silmek istiyor musunuz?" "n"; then
            delete_files="true"
        fi
    else
        if prompt_yes_no "Do you want to completely erase the files at ${sel_path}?" "n"; then
            delete_files="true"
        fi
    fi

    # Remove from registry
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s|^.*:$sel_path:.*$||" "$REGISTRY_FILE"
    else
        sed -i "s|^.*:$sel_path:.*$||" "$REGISTRY_FILE"
    fi
    sed_delete_blank_lines "$REGISTRY_FILE"

    if [ "$delete_files" = "true" ]; then
        if [ "$LANG_PREF" = "tr" ]; then
            run_with_spinner "Sunucu dosyaları siliniyor" rm -rf "$sel_path"
            log_success "Sunucu ve dosyaları başarıyla silindi."
        else
            run_with_spinner "Deleting server files" rm -rf "$sel_path"
            log_success "Server and files deleted successfully."
        fi
    else
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "Sunucu kaydı CLI'dan kaldırıldı ancak dosyalar korundu."
        else
            log_success "Server registration removed from CLI, but files were kept."
        fi
    fi

    sleep 2
}

update_server_software() {
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        log_warn "No installed servers registered."
        sleep 2
        return 1
    fi

    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_update_software" "UPDATE SERVER SOFTWARE")${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    local servers=()
    local paths=()
    local types=()
    local versions=()
    local list_options=()

    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        [ -z "$name" ] && continue
        servers+=("$name")
        paths+=("$path")
        types+=("$type")
        versions+=("$version")
        list_options+=("$name ($type $version)")
    done < "$REGISTRY_FILE"

    list_options+=("Cancel and Exit")
    local selection
    selection=$(prompt_selection "$(t "prompt_update_server" "Choose server to update:")" "${list_options[@]}")

    if [ "$selection" = "Cancel and Exit" ] || [ -z "$selection" ]; then
        return 0
    fi

    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done

    if [ "$idx" -eq -1 ]; then return 0; fi

    local s_path="${paths[$idx]}"
    local s_type="${types[$idx]}"
    local s_ver="${versions[$idx]}"
    local s_name="${servers[$idx]}"
    local sess_name; sess_name=$(get_session_name "$s_path")

    if is_server_running "$sess_name"; then
        log_error "The server must be stopped before executing an update!"
        sleep 2
        return 1
    fi

    local update_choice
    if [ "$LANG_PREF" = "tr" ]; then
        update_choice=$(prompt_selection "Lütfen güncelleme türünü seçin (Mevcut sürüm: $s_ver):" \
            "Mevcut Sürümü Güncelle (Aynı sürümün en son kararlı derlemesini indir)" \
            "Sürümü Değiştir/Yükselt (Farklı bir Minecraft sürümüne geçiş yap)" \
            "İptal Et")
    else
        update_choice=$(prompt_selection "Please choose update type (Current version: $s_ver):" \
            "Update Current Version (Download latest stable build/release for same version)" \
            "Change/Upgrade Version (Switch to a different Minecraft version)" \
            "Cancel")
    fi

    if [ "$update_choice" = "Cancel" ] || [ "$update_choice" = "İptal Et" ] || [ -z "$update_choice" ]; then
        return 0
    fi

    local download_url=""
    local new_version="$s_ver"

    if [ "$update_choice" = "Update Current Version" ] || [ "$update_choice" = "Mevcut Sürümü Güncelle" ]; then
        log_info "Fetching update options for $s_type..."
        case "$s_type" in
            vanilla)
                download_url=$(fetch_vanilla_download_url "$s_ver")
                ;;
            paper|folia|velocity|waterfall)
                local latest_build
                latest_build=$(fetch_papermc_builds "$s_type" "$s_ver" | sort -nr | head -n 1)
                log_info "Latest build resolved for $s_type $s_ver: Build $latest_build"
                download_url=$(fetch_papermc_download_url "$s_type" "$s_ver" "$latest_build")
                ;;
            purpur)
                download_url="https://api.purpurmc.org/v2/purpur/$s_ver/latest/download"
                ;;
            *)
                log_warn "Automatic in-place upgrades are not fully supported for modded configurations ($s_type)."
                log_warn "Please manually download the installer and update the jar files."
                sleep 3
                return 0
                ;;
        esac
    else
        # Change/Upgrade Version
        local back_opt
        back_opt=$(t "settings_back" "Return to Main Menu")
        case "$s_type" in
            vanilla)
                log_info "Fetching Minecraft Vanilla versions..."
                local releases
                releases=$(fetch_vanilla_releases)
                local list_options=()
                for r in $releases; do list_options+=("$r"); done
                list_options+=("$back_opt")
                new_version=$(prompt_selection "Select Minecraft version:" "${list_options[@]}")
                if [ "$new_version" = "$back_opt" ] || [ -z "$new_version" ]; then return 0; fi
                download_url=$(fetch_vanilla_download_url "$new_version")
                ;;
            paper|folia|velocity|waterfall)
                log_info "Fetching $s_type versions..."
                local versions
                versions=$(fetch_papermc_versions "$s_type")
                local list_options=()
                for v in $versions; do list_options+=("$v"); done
                list_options+=("$back_opt")
                new_version=$(prompt_selection "Select Minecraft version:" "${list_options[@]}")
                if [ "$new_version" = "$back_opt" ] || [ -z "$new_version" ]; then return 0; fi

                log_info "Fetching builds for $s_type $new_version..."
                local builds
                builds=$(fetch_papermc_builds "$s_type" "$new_version" | sort -nr)
                if [ -z "$builds" ]; then
                    log_error "No builds found for $s_type version $new_version."
                    sleep 2
                    return 1
                fi
                local build_choices=()
                for b in $builds; do build_choices+=("$b"); done
                build_choices+=("Latest Stable" "$back_opt")
                local chosen_build
                chosen_build=$(prompt_selection "Select build number:" "${build_choices[@]}")
                if [ "$chosen_build" = "$back_opt" ] || [ -z "$chosen_build" ]; then return 0; fi
                if [ "$chosen_build" = "Latest Stable" ]; then
                    local build_num=$(echo "${build_choices[0]}")
                else
                    local build_num="$chosen_build"
                fi
                download_url=$(fetch_papermc_download_url "$s_type" "$new_version" "$build_num")
                ;;
            purpur)
                log_info "Fetching Purpur versions..."
                local versions
                versions=$(fetch_purpur_versions)
                local list_options=()
                for v in $versions; do list_options+=("$v"); done
                list_options+=("$back_opt")
                new_version=$(prompt_selection "Select Minecraft version:" "${list_options[@]}")
                if [ "$new_version" = "$back_opt" ] || [ -z "$new_version" ]; then return 0; fi

                log_info "Fetching builds for Purpur $new_version..."
                local builds
                builds=$(fetch_purpur_builds "$new_version" | sort -nr)
                if [ -z "$builds" ]; then
                    log_error "No builds found for Purpur version $new_version."
                    sleep 2
                    return 1
                fi
                local build_choices=()
                for b in $builds; do build_choices+=("$b"); done
                build_choices+=("Latest Stable" "$back_opt")
                local chosen_build
                chosen_build=$(prompt_selection "Select build number:" "${build_choices[@]}")
                if [ "$chosen_build" = "$back_opt" ] || [ -z "$chosen_build" ]; then return 0; fi
                if [ "$chosen_build" = "Latest Stable" ]; then
                    local build_num="latest"
                else
                    local build_num="$chosen_build"
                fi
                download_url="https://api.purpurmc.org/v2/purpur/$new_version/$build_num/download"
                ;;
            *)
                log_warn "Automatic in-place upgrades are not fully supported for modded configurations ($s_type)."
                log_warn "Please manually download the installer and update the jar files."
                sleep 3
                return 0
                ;;
        esac
    fi

    if [ -z "$download_url" ] || [ "$download_url" = "null" ]; then
        log_error "Failed to resolve download URL."
        sleep 2
        return 1
    fi

    local jar_name="server.jar"
    [ "$s_type" = "velocity" ] && jar_name="velocity.jar"
    [ "$s_type" = "waterfall" ] && jar_name="waterfall.jar"
    [ "$s_type" = "purpur" ] && jar_name="purpur.jar"
    
    local dest_path="${s_path}/${jar_name}"

    download_file_with_progress "$download_url" "$dest_path" "updated $s_type jar"
    if [ $? -eq 0 ]; then
        log_success "Software updated successfully!"
        
        # If we upgraded to a new version, update registry config and start script java path
        if [ "$new_version" != "$s_ver" ]; then
            local escaped_path
            escaped_path=$(escape_sed_replacement "$s_path")
            local new_reg_entry="${s_name}:${s_path}:${s_type}:${new_version}"
            local escaped_entry
            escaped_entry=$(escape_sed_replacement "$new_reg_entry")
            if [[ "$OSTYPE" == "darwin"* ]]; then
                sed -i '' "s|^.*:${escaped_path}:${s_type}:.*$|${escaped_entry}|" "$REGISTRY_FILE"
            else
                sed -i "s|^.*:${escaped_path}:${s_type}:.*$|${escaped_entry}|" "$REGISTRY_FILE"
            fi
            sed_delete_blank_lines "$REGISTRY_FILE"
            log_success "Updated version registry to ${new_version}."
            
            # Dynamically update Java requirements in start.sh
            update_start_script_java_path "$s_path" "$s_type" "$new_version"
        fi
    else
        log_error "Update failed."
    fi

    sleep 2
}

configure_discord_webhook() {
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_discord_webhook" "CONFIGURE DISCORD WEBHOOK")${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    local settings_file="${SETTINGS_FILE}"
    local current_webhook=""
    if [ -f "$settings_file" ]; then
        # Load existing webhook setting safely
        current_webhook=$(grep '^DISCORD_WEBHOOK=' "$settings_file" | cut -d'"' -f2 | tr -d '\r')
    fi

    if [ -n "$current_webhook" ]; then
        echo -e "  Active Webhook URL: ${COLOR_GREEN}${current_webhook:0:55}...${COLOR_RESET}"
        if ! prompt_yes_no "Do you want to disable or update the Discord webhook?" "n"; then
            return 0
        fi
        current_webhook=""
    fi

    if [ -z "$current_webhook" ]; then
        local webhook
        webhook=$(prompt_input "Enter Discord Webhook URL (leave empty to disable)" "")

        [ -f "$settings_file" ] || {
            echo 'LANG="en"' > "$settings_file"
            echo 'DISCORD_WEBHOOK=""' >> "$settings_file"
        }

        local escaped_webhook
        escaped_webhook=$(escape_sed_replacement "$webhook")
        if [ -n "$webhook" ]; then
            if grep -q '^DISCORD_WEBHOOK=' "$settings_file"; then
                sed_in_place "s|^DISCORD_WEBHOOK=.*|DISCORD_WEBHOOK=\"${escaped_webhook}\"|" "$settings_file"
            else
                echo "DISCORD_WEBHOOK=\"${webhook}\"" >> "$settings_file"
            fi
            log_success "Discord Webhook saved successfully!"
        else
            if grep -q '^DISCORD_WEBHOOK=' "$settings_file"; then
                sed_in_place 's|^DISCORD_WEBHOOK=.*|DISCORD_WEBHOOK=""|' "$settings_file"
            else
                echo 'DISCORD_WEBHOOK=""' >> "$settings_file"
            fi
            log_success "Discord Webhook disabled."
        fi
    fi

    sleep 2
}

