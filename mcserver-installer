                list_and_remove_plugins "$server_path"
                ;;
            3)
                break
                ;;
            *)
                log_warn "$(t "invalid_sel" "Invalid selection.")"
                sleep 1.5
                ;;
        esac
    done
}

search_and_install_plugin() {
    local server_path="$1"
    local s_ver="$2"
    local s_type="$3"
    shift 3
    local loaders=("$@")

    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_search_plugins" "SEARCH AND INSTALL PLUGINS")${COLOR_RESET}\n"

    local query
    query=$(prompt_input "$(t "plugin_search_prompt" "Enter plugin name to search")" "")
    if [ -z "$query" ]; then
        log_warn "$(t "plugin_search_empty" "Search query cannot be empty.")"
        sleep 1.5
        return 1
    fi

    local url_query
    url_query=$(echo -n "$query" | jq -sRr @uri)

    log_info "$(t "plugin_searching" "Searching Modrinth API...")"
    local res
    res=$(curl -s "https://api.modrinth.com/v2/search?query=${url_query}&facets=%5B%5B%22project_type:plugin%22%5D%5D")

    local count
    count=$(echo "$res" | jq '.hits | length' 2>/dev/null || echo 0)
    if [ -z "$count" ] || [ "$count" -eq 0 ]; then
        log_warn "$(t "plugin_not_found" "No plugins found for search term.")"
        sleep 2
        return 1
    fi

    local hits
    hits=$(echo "$res" | jq -c '.hits[]')

    local titles=()
    local ids=()
    local slugs=()

    while IFS= read -r hit || [ -n "$hit" ]; do
        [ -z "$hit" ] && continue
        local title; title=$(echo "$hit" | jq -r '.title')
        local id; id=$(echo "$hit" | jq -r '.project_id')
        local slug; slug=$(echo "$hit" | jq -r '.slug')
        local desc; desc=$(echo "$hit" | jq -r '.description // ""' | cut -c1-50)
        titles+=("${title} (${slug}) - ${desc}")
        ids+=("$id")
        slugs+=("$slug")
    done <<< "$hits"

    local chosen
    chosen=$(prompt_selection "$(t "prompt_install_plugin" "Select plugin to install:")" "${titles[@]}")

    local idx=-1
    for i in "${!titles[@]}"; do
        if [ "${titles[$i]}" = "$chosen" ]; then
            idx=$i
            break
        fi
    done

    if [ "$idx" -eq -1 ]; then
        return 1
    fi

    local project_id="${ids[$idx]}"
    local project_slug="${slugs[$idx]}"

    log_info "$(t "plugin_fetching_versions" "Fetching available versions for") ${project_slug}..."
    local res_ver
    res_ver=$(curl -s "https://api.modrinth.com/v2/project/${project_id}/version")

    local loader_json
    loader_json=$(printf '%s\n' "${loaders[@]}" | jq -R . | jq -s -c .)

    local matched_versions
    matched_versions=$(echo "$res_ver" | jq --arg ver "$s_ver" --argjson lds "$loader_json" -c '
        map(select(
            (.game_versions | contains([$ver])) and
            (.loaders | unique | . - ($unique = . | . - $lds) | length > 0)
        ))
    ' 2>/dev/null || echo "[]")

    local matched_count
    matched_count=$(echo "$matched_versions" | jq 'length' 2>/dev/null || echo 0)

    local chosen_ver_obj=""
    if [ "$matched_count" -gt 0 ]; then
        local v_names=()
        local v_ids=()

        while IFS= read -r row || [ -n "$row" ]; do
            [ -z "$row" ] && continue
            local name; name=$(echo "$row" | jq -r '.name')
            local num; num=$(echo "$row" | jq -r '.version_number')
            local id; id=$(echo "$row" | jq -r '.id')
            v_names+=("${name} [Ver: ${num}] (Recommended)")
            v_ids+=("$id")
        done <<< "$(echo "$matched_versions" | jq -c '.[]')"

        local chosen_name
        chosen_name=$(prompt_selection "$(t "prompt_plugin_compat" "Select compatible version to install:")" "${v_names[@]}")

        local v_idx=-1
        for i in "${!v_names[@]}"; do
            if [ "${v_names[$i]}" = "$chosen_name" ]; then
                v_idx=$i
                break
            fi
        done

        if [ "$v_idx" -ne -1 ]; then
            chosen_ver_obj=$(echo "$matched_versions" | jq -c ".[${v_idx}]")
        fi
    else
        echo -e ""
        log_warn "$(t "plugin_no_compat" "No exact compatible versions found for Minecraft") ${s_ver} on ${s_type}."
        if prompt_yes_no "$(t "plugin_ask_all" "Would you like to list all available versions instead?")" "y"; then
            local all_names=()
            local all_ids=()

            while IFS= read -r row || [ -n "$row" ]; do
                [ -z "$row" ] && continue
                local name; name=$(echo "$row" | jq -r '.name')
                local num; num=$(echo "$row" | jq -r '.version_number')
                local id; id=$(echo "$row" | jq -r '.id')
                all_names+=("${name} [Ver: ${num}]")
                all_ids+=("$id")
            done <<< "$(echo "$res_ver" | jq -c '.[]' | head -n 10)"

            local chosen_name
            chosen_name=$(prompt_selection "$(t "prompt_plugin_risk" "Select version to install (at your own risk):")" "${all_names[@]}")

            local v_idx=-1
            for i in "${!all_names[@]}"; do
                if [ "${all_names[$i]}" = "$chosen_name" ]; then
                    v_idx=$i
                    break
                fi
            done

            if [ "$v_idx" -ne -1 ]; then
                chosen_ver_obj=$(echo "$res_ver" | jq -c ".[${v_idx}]")
            fi
        fi
    fi

    if [ -n "$chosen_ver_obj" ]; then
        local dl_url
        dl_url=$(echo "$chosen_ver_obj" | jq -r '.files[0].url')
        local dl_name
        dl_name=$(echo "$chosen_ver_obj" | jq -r '.files[0].filename')

        if [ -n "$dl_url" ] && [ "$dl_url" != "null" ]; then
            local plugins_dir="${server_path}/plugins"
            mkdir -p "$plugins_dir"

            run_with_spinner "$(t "plugin_downloading" "Downloading plugin") ${dl_name}..." curl -s -L -o "${plugins_dir}/${dl_name}" "$dl_url"
            log_success "Plugin ${dl_name} $(t "plugin_success" "installed successfully!")"
            send_discord_notification "Plugin installed: ${dl_name}" 3066993 "$server_path"
            sleep 2
        else
            log_error "$(t "plugin_fail_url" "Failed to resolve download URL for selected version.")"
            sleep 2
        fi
    fi
}

list_and_remove_plugins() {
    local server_path="$1"
    local plugins_dir="${server_path}/plugins"

    if [ ! -d "$plugins_dir" ] || [ -z "$(ls -A "$plugins_dir" 2>/dev/null | grep '\.jar$')" ]; then
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_remove_plugins" "LIST AND REMOVE PLUGINS")${COLOR_RESET}\n"
        log_warn "$(t "plugin_none_dir" "No plugins found in plugins directory.")"
        sleep 2
        return 1
    fi

    local files=()
    for f in "$plugins_dir"/*.jar; do
        [ -f "$f" ] && files+=("$(basename "$f")")
    done

    if [ ${#files[@]} -eq 0 ]; then
        log_warn "$(t "plugin_none_jar" "No plugin jar files found.")"
        sleep 2
        return 1
    fi

    files+=("$(t "settings_back" "Return to Main Menu")")

    local chosen
    chosen=$(prompt_selection "$(t "prompt_remove_plugin" "Select a plugin jar to remove:")" "${files[@]}")

    if [ "$chosen" = "$(t "settings_back" "Return to Main Menu")" ]; then
        return 0
    fi

    local confirm_msg
    if [ "$LANG_PREF" = "tr" ]; then
        confirm_msg="${chosen} eklentisini silmek istediğinizden emin misiniz?"
    else
        confirm_msg="Are you sure you want to delete ${chosen}?"
    fi

    if prompt_yes_no "$confirm_msg" "n"; then
        rm -f "${plugins_dir}/${chosen}"

        local success_msg
        if [ "$LANG_PREF" = "tr" ]; then
            success_msg="${chosen} eklentisi başarıyla kaldırıldı!"
        else
            success_msg="Plugin ${chosen} removed successfully!"
        fi
        log_success "$success_msg"
        send_discord_notification "Plugin removed: ${chosen}" 15158332 "$server_path"
        sleep 2
    else
        log_info "$(t "delete_canceled" "Deletion canceled.")"
    fi
}

download_modrinth_plugin_by_slug() {
    local slug="$1"
    local dest_dir="$2"
    local mc_ver="$3"

    log_info "Fetching latest release for ${slug}..."
    local res_ver
    res_ver=$(curl -s -H "${UA_HEADER}" "https://api.modrinth.com/v2/project/${slug}/version")
    if [ -z "$res_ver" ] || [ "$res_ver" = "null" ]; then
        log_error "Failed to fetch versions for ${slug}."
        return 1
    fi

    local dl_url
    dl_url=$(echo "$res_ver" | jq -r --arg ver "$mc_ver" '
        map(select(.game_versions | contains([$ver]))) | .[0].files[0].url
    ' 2>/dev/null)

    if [ -z "$dl_url" ] || [ "$dl_url" = "null" ]; then
        dl_url=$(echo "$res_ver" | jq -r '.[0].files[0].url' 2>/dev/null)
    fi

    if [ -z "$dl_url" ] || [ "$dl_url" = "null" ]; then
        log_error "No valid download URL found for ${slug}."
        return 1
    fi

    local filename; filename=$(basename "$dl_url")
    run_with_spinner "Downloading ${filename}..." curl -s -L -o "${dest_dir}/${filename}" "$dl_url"
    log_success "Downloaded ${filename} successfully."
}

install_geyser_floodgate() {
    local s_name="$1"
    local server_path="$2"
    local s_type="$3"
    local s_ver="${4:-latest}"

    local platform=""
    case "$s_type" in
        paper|purpur|spigot|folia)
            platform="spigot"
            ;;
        velocity)
            platform="velocity"
            ;;
        bungeecord|waterfall)
            platform="bungeecord"
            ;;
        *)
            log_error "GeyserMC & Floodgate auto-installer currently supports Spigot, Paper, Purpur, Velocity, BungeeCord, and Waterfall servers."
            sleep 3
            return 1
            ;;
    esac

    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_install_geyser" "INSTALL GEYSERMC & FLOODGATE (CROSS-PLAY)")${COLOR_RESET}"
    echo -e "  Server: $s_name | Platform: $platform"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    local plugins_dir="${server_path}/plugins"
    mkdir -p "$plugins_dir"

    local geyser_url="https://download.geysermc.org/v2/projects/geyser/versions/latest/builds/latest/downloads/${platform}"
    local floodgate_url="https://download.geysermc.org/v2/projects/floodgate/versions/latest/builds/latest/downloads/${platform}"

    run_with_spinner "Downloading GeyserMC (${platform})..." curl -s -L -o "${plugins_dir}/Geyser.jar" "$geyser_url"
    run_with_spinner "Downloading Floodgate (${platform})..." curl -s -L -o "${plugins_dir}/Floodgate.jar" "$floodgate_url"

    log_success "GeyserMC and Floodgate downloaded successfully into plugins folder!"

    echo -e ""
    local install_via="n"
    if [ "$LANG_PREF" = "tr" ]; then
        if prompt_yes_no "Farklı istemci sürümlerinin (daha yeni Bedrock sürümleri dahil) bağlanabilmesi için ViaVersion ve ViaBackwards kurmak ister misiniz?" "y"; then
            install_via="y"
        fi
    else
        if prompt_yes_no "Would you like to install ViaVersion and ViaBackwards to support different client versions (including newer Bedrock clients)?" "y"; then
            install_via="y"
        fi
    fi

    if [ "$install_via" = "y" ]; then
        download_modrinth_plugin_by_slug "viaversion" "$plugins_dir" "$s_ver"
        download_modrinth_plugin_by_slug "viabackwards" "$plugins_dir" "$s_ver"
    fi

    if command -v ufw &>/dev/null; then
        local ufw_status
        ufw_status=$(sudo ufw status 2>/dev/null || ufw status 2>/dev/null || echo "inactive")
        if echo "$ufw_status" | grep -q "Status: active"; then
            if ! echo "$ufw_status" | grep -q "19132/udp"; then
                echo -e ""
                log_warn "UFW firewall is active, but Bedrock UDP port 19132 is NOT allowed!"
                if prompt_yes_no "Would you like to open UDP port 19132 in UFW automatically?" "y"; then
                    if [ "$EUID" -ne 0 ]; then
                        run_with_spinner "Opening UDP port 19132 in UFW (via sudo)" sudo ufw allow 19132/udp
                    else
                        run_with_spinner "Opening UDP port 19132 in UFW" ufw allow 19132/udp
                    fi
                fi
            fi
        fi
    fi

    send_discord_notification "GeyserMC and Floodgate installed on ${s_name}." 3066993 "$server_path"

    echo -e "\n  Please restart your Minecraft server for GeyserMC & Floodgate to load."
    echo -n "  Press [Enter] to return: "
    read -r _
}

optimize_server_performance() {
    local s_path="$1"
    local s_type="$2"

    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_optimize" "SERVER OPTIMIZATION ENGINE")${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    if [ "$LANG_PREF" = "tr" ]; then
        log_info "Sunucu performans dosyaları optimize ediliyor..."
    else
        log_info "Optimizing server performance configuration files..."
    fi
    sleep 1

    # 1. Optimize server.properties (if exists)
    local prop_file="${s_path}/server.properties"
    if [ -f "$prop_file" ]; then
        set_property_val "$prop_file" "view-distance" "6"
        set_property_val "$prop_file" "simulation-distance" "5"
        set_property_val "$prop_file" "network-compression-threshold" "256"
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "server.properties optimize edildi (Görüş mesafesi: 6, Simülasyon: 5)."
        else
            log_success "server.properties optimized (View distance: 6, Simulation: 5)."
        fi
    fi

    # 2. Optimize spigot.yml (if exists)
    local spigot_file="${s_path}/spigot.yml"
    if [ -f "$spigot_file" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' 's/save-user-cache-on-stop-only:.*/save-user-cache-on-stop-only: true/' "$spigot_file"
            sed -i '' 's/animals:.*/animals: 16/' "$spigot_file"
            sed -i '' 's/monsters:.*/monsters: 24/' "$spigot_file"
        else
            sed -i 's/save-user-cache-on-stop-only:.*/save-user-cache-on-stop-only: true/' "$spigot_file"
            sed -i 's/animals:.*/animals: 16/' "$spigot_file"
            sed -i 's/monsters:.*/monsters: 24/' "$spigot_file"
        fi
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "spigot.yml optimize edildi (Varlık aktivasyon alanları azaltıldı)."
        else
            log_success "spigot.yml optimized (Entity activation ranges reduced)."
        fi
    fi

    # 3. Optimize paper configurations (paper.yml or config/paper-global.yml)
    local paper_global="${s_path}/config/paper-global.yml"
    local legacy_paper="${s_path}/paper.yml"
    if [ -f "$paper_global" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' 's/max-auto-save-chunks-per-tick:.*/max-auto-save-chunks-per-tick: 6/' "$paper_global"
        else
            sed -i 's/max-auto-save-chunks-per-tick:.*/max-auto-save-chunks-per-tick: 6/' "$paper_global"
        fi
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "paper-global.yml optimize edildi (Otomatik kaydetme limiti ayarlandı)."
        else
            log_success "paper-global.yml optimized (Auto-save limits tuned)."
        fi
    elif [ -f "$legacy_paper" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' 's/max-auto-save-chunks-per-tick:.*/max-auto-save-chunks-per-tick: 6/' "$legacy_paper"
        else
            sed -i 's/max-auto-save-chunks-per-tick:.*/max-auto-save-chunks-per-tick: 6/' "$legacy_paper"
        fi
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "paper.yml optimize edildi."
        else
            log_success "paper.yml optimized."
        fi
    fi

    # 4. Inject Aikar's JVM performance flags to start.sh or user_jvm_args.txt
    local aikars_flags="-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8m -XX:G1ReservePercent=15 -XX:G1HeapWastePercent=5 -XX:G1MixedGCCountTarget=4 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1RSetUpdatingPauseTimePercent=5 -XX:SurvivorRatio=32 -XX:+PerfDisableSharedMem -XX:MaxTenuringThreshold=1"

    # If user_jvm_args.txt exists (Forge/NeoForge standard)
    local jvm_args_file="${s_path}/user_jvm_args.txt"
    if [ -f "$jvm_args_file" ]; then
        # Check if already optimized
        if ! grep -q "UseG1GC" "$jvm_args_file"; then
            echo "$aikars_flags" >> "$jvm_args_file"
        fi
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "user_jvm_args.txt dosyasına Aikar garbage collection parametreleri eklendi."
        else
            log_success "Aikar's Garbage Collection JVM flags added to user_jvm_args.txt."
        fi
    fi

    # If start.sh exists, inject into the java command line
    local start_script="${s_path}/start.sh"
    if [ -f "$start_script" ]; then
        # Replace the java execution line to include Aikar's flags
        if ! grep -q "UseG1GC" "$start_script"; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                sed -i '' "s|exec java |exec java ${aikars_flags} |" "$start_script"
                sed -i '' "s|java -X|java ${aikars_flags} -X|" "$start_script"
            else
                sed -i "s|exec java |exec java ${aikars_flags} |" "$start_script"
                sed -i "s|java -X|java ${aikars_flags} -X|" "$start_script"
            fi
        fi
        if [ "$LANG_PREF" = "tr" ]; then
            log_success "start.sh başlatıcı komutuna Aikar garbage collection parametreleri eklendi."
        else
            log_success "Aikar's Garbage Collection JVM flags injected into start.sh."
        fi
    fi

    echo ""
    if [ "$LANG_PREF" = "tr" ]; then
        log_success "Optimizasyon başarıyla tamamlandı! Lütfen değişikliklerin etkinleşmesi için sunucuyu yeniden başlatın."
    else
        log_success "Optimization completed successfully! Please restart the server to apply the changes."
    fi
    sleep 3
}

