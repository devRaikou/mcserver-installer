# --- Logging Helpers ---
log_info() { echo -e "  ${COLOR_BLUE}${ICON_INFO} $*${COLOR_RESET}" >&2; }
log_success() { echo -e "  ${COLOR_GREEN}${ICON_SUCCESS} $*${COLOR_RESET}" >&2; }
log_warn() { echo -e "  ${COLOR_YELLOW}${ICON_WARNING} $*${COLOR_RESET}" >&2; }
log_error() { echo -e "  ${COLOR_RED}${ICON_ERROR} $*${COLOR_RESET}" >&2; }

sed_in_place() {
    local expr="$1"
    local file="$2"
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "$expr" "$file"
    else
        sed -i "$expr" "$file"
    fi
}

sed_delete_blank_lines() {
    sed_in_place '/^[[:space:]]*$/d' "$1"
}

escape_sed_replacement() {
    printf '%s' "$1" | sed 's/[&|\\]/\\&/g'
}

is_valid_port() {
    local port="$1"
    [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -ge 1 ] && [ "$port" -le 65535 ]
}

is_valid_ram_value() {
    [[ "$1" =~ ^[1-9][0-9]*[MmGg]$ ]]
}

is_registry_safe_value() {
    [[ "$1" != *:* && "$1" != *$'\n'* && "$1" != *$'\r'* ]]
}

prompt_port_input() {
    local msg="$1"
    local default="$2"
    local port
    while true; do
        port=$(prompt_input "$msg" "$default")
        if is_valid_port "$port"; then
            echo "$port"
            return 0
        fi
        log_warn "Invalid port. Enter a number between 1 and 65535."
    done
}

prompt_ram_input() {
    local msg="$1"
    local default="$2"
    local value
    while true; do
        value=$(prompt_input "$msg" "$default")
        if is_valid_ram_value "$value"; then
            echo "$value"
            return 0
        fi
        log_warn "Invalid RAM value. Use a positive value ending in M or G, for example 1024M or 4G."
    done
}

send_discord_notification() {
    local msg="$1"
    local color="${2:-3066993}"
    local server_path="${3:-}"
    local extra_field_name="${4:-}"
    local extra_field_val="${5:-}"

    local settings_file="${SETTINGS_FILE}"
    if [ -f "$settings_file" ]; then
        local webhook
        webhook=$(grep '^DISCORD_WEBHOOK=' "$settings_file" | cut -d'"' -f2 | tr -d '\r')
        if [ -n "$webhook" ]; then
            local s_name="Unknown"
            local s_type="Unknown"
            local s_ver="Unknown"
            local local_ip="Unknown"
            local public_ip="Unknown"
            local port="Unknown"

            if [ -n "$server_path" ] && [ -f "$REGISTRY_FILE" ]; then
                local abs_target
                abs_target=$(cd "$server_path" 2>/dev/null && pwd -P || echo "$server_path")

                while IFS=":" read -r r_name r_path r_type r_ver || [ -n "$r_name" ]; do
                    [ -z "$r_name" ] && continue
                    local abs_reg
                    abs_reg=$(cd "$r_path" 2>/dev/null && pwd -P || echo "$r_path")
                    if [ "$abs_target" = "$abs_reg" ]; then
                        s_name="$r_name"
                        s_type="$r_type"
                        s_ver="$r_ver"
                        local_ip=$(get_local_ip)
                        public_ip=$(cat "${CONFIG_DIR}/.public_ip" 2>/dev/null || echo "Unknown")
                        [ -z "$public_ip" ] && public_ip="Unknown"
                        port=$(get_server_port "$r_path" "$s_type")
                        break
                    fi
                done < "$REGISTRY_FILE"
            fi

            local timestamp
            timestamp=$(date -u +%Y-%m-%dT%H:%M:%SZ)
            local connection_address
            connection_address=$(printf '`%s:%s` (Public)\n`%s:%s` (Local)' "$public_ip" "$port" "$local_ip" "$port")
            local payload
            payload=$(jq -n \
                --arg msg "$msg" \
                --argjson color "$color" \
                --arg timestamp "$timestamp" \
                --arg server_name "$s_name" \
                --arg software "${s_type} (${s_ver})" \
                --arg connection "$connection_address" \
                --arg extra_name "$extra_field_name" \
                --arg extra_val "$extra_field_val" '
                def extra_fields:
                    if (($extra_name | length) > 0 and ($extra_val | length) > 0) then
                        [{name: $extra_name, value: $extra_val, inline: true}]
                    else
                        []
                    end;
                {
                    embeds: [
                        ({
                            title: "mcserver-installer",
                            description: $msg,
                            color: $color,
                            footer: {text: "mcserver-installer"},
                            timestamp: $timestamp
                        } + (
                            if $server_name != "Unknown" then
                                {fields: ([
                                    {name: "Server Name", value: $server_name, inline: true},
                                    {name: "Software & Version", value: $software, inline: true},
                                    {name: "Connection Address", value: $connection, inline: false}
                                ] + extra_fields)}
                            elif ((extra_fields | length) > 0) then
                                {fields: extra_fields}
                            else
                                {}
                            end
                        ))
                    ]
                }')

            (
                curl -s -H "Content-Type: application/json" \
                     -X POST \
                     -d "$payload" \
                     "$webhook" >/dev/null 2>&1
            ) &
        fi
    fi
}

