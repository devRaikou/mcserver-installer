launch_web_dashboard() {
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_web_dashboard" "WEB DASHBOARD")${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    # 1. Dependency checks
    if ! command -v node &>/dev/null || ! command -v npm &>/dev/null; then
        if [ "$LANG_PREF" = "tr" ]; then
            log_error "Node.js veya npm kurulu değil! Web paneli çalıştırılamıyor."
            log_info "Lütfen sisteminize Node.js kurun ve tekrar deneyin."
        else
            log_error "Node.js or npm is not installed! Cannot launch Web Dashboard."
            log_info "Please install Node.js on your system and try again."
        fi
        sleep 3
        return 1
    fi

    local dashboard_dir="${SCRIPT_DIR}/dashboard"

    local force_npm_install="false"

    # Auto-download dashboard files if missing or outdated compared to current APP_VERSION
    if [ ! -f "${dashboard_dir}/package.json" ] || [ ! -f "${dashboard_dir}/server.js" ] || [ ! -f "${dashboard_dir}/public/index.html" ] || [ ! -f "${dashboard_dir}/.version" ] || [ "$(cat "${dashboard_dir}/.version" 2>/dev/null || echo "")" != "$APP_VERSION" ]; then
        if [ "$LANG_PREF" = "tr" ]; then
            log_info "Web paneli dosyaları eksik veya eski sürüm. GitHub'dan güncelleniyor..."
        else
            log_info "Web dashboard files are missing or outdated. Syncing from GitHub..."
        fi

        mkdir -p "${dashboard_dir}/public"
        local base_url="https://raw.githubusercontent.com/devRaikou/mcserver-installer/main/dashboard"

        if [ "$LANG_PREF" = "tr" ]; then
            run_with_spinner "package.json indiriliyor" curl -s -L -H "Cache-Control: no-cache" -o "${dashboard_dir}/package.json" "${base_url}/package.json?t=$(date +%s)"
            run_with_spinner "server.js indiriliyor" curl -s -L -H "Cache-Control: no-cache" -o "${dashboard_dir}/server.js" "${base_url}/server.js?t=$(date +%s)"
            run_with_spinner "index.html indiriliyor" curl -s -L -H "Cache-Control: no-cache" -o "${dashboard_dir}/public/index.html" "${base_url}/public/index.html?t=$(date +%s)"
        else
            run_with_spinner "Downloading package.json" curl -s -L -H "Cache-Control: no-cache" -o "${dashboard_dir}/package.json" "${base_url}/package.json?t=$(date +%s)"
            run_with_spinner "Downloading server.js" curl -s -L -H "Cache-Control: no-cache" -o "${dashboard_dir}/server.js" "${base_url}/server.js?t=$(date +%s)"
            run_with_spinner "Downloading index.html" curl -s -L -H "Cache-Control: no-cache" -o "${dashboard_dir}/public/index.html" "${base_url}/public/index.html?t=$(date +%s)"
        fi

        if [ ! -f "${dashboard_dir}/package.json" ] || [ ! -f "${dashboard_dir}/server.js" ] || [ ! -f "${dashboard_dir}/public/index.html" ]; then
            if [ "$LANG_PREF" = "tr" ]; then
                log_error "Dosyalar indirilemedi! Lütfen ağ bağlantısını kontrol edin."
            else
                log_error "Failed to download dashboard files! Please check your network connection."
            fi
            sleep 3
            return 1
        fi
        echo "$APP_VERSION" > "${dashboard_dir}/.version"
        force_npm_install="true"
    fi

    # 2. Check if node_modules is installed


    if [ ! -d "${dashboard_dir}/node_modules" ] || [ "$force_npm_install" = "true" ]; then
        if [ "$LANG_PREF" = "tr" ]; then
            log_info "Web paneli bağımlılıkları yükleniyor (npm install)..."
            run_with_spinner "Bağımlılıklar yükleniyor" npm --prefix "$dashboard_dir" install
        else
            log_info "Installing web dashboard dependencies (npm install)..."
            run_with_spinner "Installing dependencies" npm --prefix "$dashboard_dir" install
        fi
        if [ $? -ne 0 ]; then
            if [ "$LANG_PREF" = "tr" ]; then
                log_error "Bağımlılıklar yüklenemedi!"
            else
                log_error "Failed to install dependencies!"
            fi
            sleep 3
            return 1
        fi
    fi

    # 3. Check if dashboard is already running
    if screen -list | grep -q "\.mc-dashboard"; then
        local running_port="3000"
        if [ -f "${CONFIG_DIR}/.dashboard_port" ]; then
            running_port=$(cat "${CONFIG_DIR}/.dashboard_port" | tr -d '[:space:]')
        fi
        local running_otp=""
        local users_file="${CONFIG_DIR}/.users.json"
        if [ -f "$users_file" ]; then
            running_otp=$(jq -r '.[] | select(.username=="admin") | .pin' "$users_file" 2>/dev/null || true)
        fi
        local running_domain=""
        if [ -f "$SETTINGS_FILE" ]; then
            running_domain=$(grep '^DASHBOARD_DOMAIN=' "$SETTINGS_FILE" | cut -d'"' -f2 | tr -d '\r' || true)
        fi
        local running_ip="127.0.0.1"
        if command -v hostname &>/dev/null; then
            running_ip=$(hostname -I | awk '{print $1}')
        fi
        if [ -z "$running_ip" ]; then
            running_ip=$(ip route get 1 2>/dev/null | awk '{print $7}')
        fi
        if [ -z "$running_ip" ]; then
            running_ip=$(ifconfig | grep "inet " | grep -v "127.0.0.1" | awk '{print $2}' | head -n 1)
        fi
        [ -z "$running_ip" ] && running_ip="127.0.0.1"

        if [ "$LANG_PREF" = "tr" ]; then
            echo -e "  ${COLOR_YELLOW}Web Kontrol Paneli şu anda arka planda aktif.${COLOR_RESET}"
            echo -e "  ----------------------------------------------------------------"
            echo -e "  - Yerel Erişim:  ${COLOR_CYAN}http://localhost:${running_port}${COLOR_RESET}"
            echo -e "  - Ağ Üzerinden:  ${COLOR_CYAN}http://${running_ip}:${running_port}${COLOR_RESET}"
            if [ -n "$running_domain" ]; then
                echo -e "  - Domain Adresi: ${COLOR_CYAN}http://${running_domain}${COLOR_RESET}"
            fi
            echo -e "  - Giriş Şifresi (OTP PIN): ${COLOR_GREEN}${running_otp}${COLOR_RESET}"
            echo -e "  ----------------------------------------------------------------\n"
        else
            echo -e "  ${COLOR_YELLOW}Web Dashboard is currently active in the background.${COLOR_RESET}"
            echo -e "  ----------------------------------------------------------------"
            echo -e "  - Local Link:    ${COLOR_CYAN}http://localhost:${running_port}${COLOR_RESET}"
            echo -e "  - Network Link:  ${COLOR_CYAN}http://${running_ip}:${running_port}${COLOR_RESET}"
            if [ -n "$running_domain" ]; then
                echo -e "  - Domain Link:   ${COLOR_CYAN}http://${running_domain}${COLOR_RESET}"
            fi
            echo -e "  - Access PIN (OTP Code): ${COLOR_GREEN}${running_otp}${COLOR_RESET}"
            echo -e "  ----------------------------------------------------------------\n"
        fi

        local choice
        if [ "$LANG_PREF" = "tr" ]; then
            choice=$(prompt_selection "Lütfen bir işlem seçin:" "Paneli Durdur" "Paneli Yeniden Başlat" "Domain Bağla / Değiştir" "Ana Menüye Dön")
        else
            choice=$(prompt_selection "Please select an action:" "Stop Dashboard" "Restart Dashboard" "Bind / Change Domain" "Return to Main Menu")
        fi

        case "$choice" in
            "Paneli Durdur"|"Stop Dashboard")
                screen -S mc-dashboard -X quit &>/dev/null
                
                # Cleanup Nginx reverse proxy configuration if present
                if [ -n "$running_domain" ]; then
                    sudo rm -f "/etc/nginx/sites-available/${running_domain}"
                    sudo rm -f "/etc/nginx/sites-enabled/${running_domain}"
                    if command -v systemctl &>/dev/null; then
                        sudo systemctl reload nginx &>/dev/null
                    else
                        sudo service nginx reload &>/dev/null
                    fi
                    if [[ "$OSTYPE" == "darwin"* ]]; then
                        sed -i '' '/^DASHBOARD_DOMAIN=/d' "$SETTINGS_FILE"
                    else
                        sed -i '/^DASHBOARD_DOMAIN=/d' "$SETTINGS_FILE"
                    fi
                fi

                # Delete all dashboard directory, port and OTP tracking files
                rm -rf "${dashboard_dir}"
                rm -f "${CONFIG_DIR}/.users.json"
                rm -f "${CONFIG_DIR}/.dashboard_port"

                if [ "$LANG_PREF" = "tr" ]; then
                    log_success "Web paneli durduruldu, tüm panel dosyaları ve kayıtları temizlendi."
                else
                    log_success "Web dashboard stopped and all related files/records have been cleared."
                fi
                sleep 2
                return 0
                ;;
            "Paneli Yeniden Başlat"|"Restart Dashboard")
                screen -S mc-dashboard -X quit &>/dev/null
                sleep 1
                ;;
            "Domain Bağla / Değiştir"|"Bind / Change Domain")
                echo -e ""
                local prompt_msg="Kontrol paneline bir domain (alan adı) bağlamak ister misiniz?"
                [ -n "$running_domain" ] && prompt_msg="Mevcut bağlı domain: ${COLOR_GREEN}${running_domain}${COLOR_RESET}. Değiştirmek veya yeni bir domain bağlamak ister misiniz?"
                if [ "$LANG_PREF" = "tr" ]; then
                    if prompt_yes_no "$prompt_msg" "n"; then
                        echo -n -e "  ${COLOR_CYAN}Lütfen bağlamak istediğiniz domain adını girin (Boş bırakırsanız mevcut domain kaldırılır):${COLOR_RESET} "
                        local domain_input
                        read -r domain_input
                        bind_dashboard_domain "$domain_input"
                    fi
                else
                    local prompt_msg_en="Would you like to bind a domain (subdomain) to this dashboard?"
                    [ -n "$running_domain" ] && prompt_msg_en="Current bound domain: ${COLOR_GREEN}${running_domain}${COLOR_RESET}. Would you like to change or bind a new one?"
                    if prompt_yes_no "$prompt_msg_en" "n"; then
                        echo -n -e "  ${COLOR_CYAN}Please enter the domain name you want to bind (leave empty to remove existing domain):${COLOR_RESET} "
                        local domain_input
                        read -r domain_input
                        bind_dashboard_domain "$domain_input"
                    fi
                fi
                echo -e -n "\n  $(t "press_enter" "Press [Enter] to continue: ")"
                read -r _
                return 0
                ;;
            *)
                return 0
                ;;
        esac
    fi

    # 4. Launch Dashboard
    if [ "$LANG_PREF" = "tr" ]; then
        log_info "Web paneli arka planda başlatılıyor..."
    else
        log_info "Launching Web Dashboard in the background..."
    fi

    # Clear old port file and always generate a fresh OTP on dashboard launch
    rm -f "${CONFIG_DIR}/.dashboard_port"
    local users_file="${CONFIG_DIR}/.users.json"
    local otp_code=$((100000 + RANDOM % 900000))
    
    if [ ! -f "$users_file" ]; then
        echo "[{\"username\":\"admin\",\"pin\":\"$otp_code\",\"role\":\"admin\"}]" > "$users_file"
    else
        jq "map(if .username == \"admin\" then .pin = \"$otp_code\" else . end)" "$users_file" > "${users_file}.tmp" 2>/dev/null || true
        [ -s "${users_file}.tmp" ] && mv "${users_file}.tmp" "$users_file"
    fi

    screen -dmS mc-dashboard bash -c "cd '${dashboard_dir}' && CONFIG_DIR='${CONFIG_DIR}' node server.js"
    
    # Wait for the backend to start and write the active port
    local count=0
    local active_port="3000"
    while [ ! -f "${CONFIG_DIR}/.dashboard_port" ] && [ $count -lt 12 ]; do
        sleep 0.5
        count=$((count + 1))
    done

    if [ -f "${CONFIG_DIR}/.dashboard_port" ]; then
        active_port=$(cat "${CONFIG_DIR}/.dashboard_port" | tr -d '[:space:]')
    fi

    # Open port in UFW if active
    if command -v ufw &>/dev/null; then
        if sudo ufw status 2>/dev/null | grep -q "Status: active"; then
            if [ "$LANG_PREF" = "tr" ]; then
                log_info "UFW güvenlik duvarı aktif. Kontrol paneli portuna (${active_port}) izin veriliyor..."
            else
                log_info "UFW firewall is active. Allowing dashboard port ${active_port}..."
            fi
            sudo ufw allow "${active_port}/tcp" &>/dev/null
        fi
    fi

    local dashboard_domain=""
    if [ -f "$SETTINGS_FILE" ]; then
        dashboard_domain=$(grep '^DASHBOARD_DOMAIN=' "$SETTINGS_FILE" | cut -d'"' -f2 | tr -d '\r' || true)
    fi

    if screen -list | grep -q "\.mc-dashboard"; then
        local local_ip="127.0.0.1"
        if command -v hostname &>/dev/null; then
            local_ip=$(hostname -I | awk '{print $1}')
        fi
        if [ -z "$local_ip" ]; then
            local_ip=$(ip route get 1 2>/dev/null | awk '{print $7}')
        fi
        if [ -z "$local_ip" ]; then
            local_ip=$(ifconfig | grep "inet " | grep -v "127.0.0.1" | awk '{print $2}' | head -n 1)
        fi
        [ -z "$local_ip" ] && local_ip="127.0.0.1"

        if [ "$LANG_PREF" = "tr" ]; then
            log_success "Web paneli başarıyla başlatıldı!"
            echo -e "\n  Paneli tarayıcınızdan açmak için aşağıdaki bağlantıları kullanın:"
            echo -e "  - Yerel Erişim:  ${COLOR_CYAN}http://localhost:${active_port}${COLOR_RESET}"
            echo -e "  - Ağ Üzerinden:  ${COLOR_CYAN}http://${local_ip}:${active_port}${COLOR_RESET}"
            if [ -n "$dashboard_domain" ]; then
                echo -e "  - Domain Adresi: ${COLOR_CYAN}http://${dashboard_domain}${COLOR_RESET}"
            fi
            echo -e "  - Giriş Şifresi (OTP PIN): ${COLOR_GREEN}${otp_code}${COLOR_RESET}\n"
            echo -e "  ${COLOR_YELLOW}Not:${COLOR_RESET} Eğer AWS, Hetzner veya Google Cloud gibi bir bulut sağlayıcı kullanıyorsanız,"
            echo -e "  bulut panelinizden ${COLOR_GREEN}${active_port}${COLOR_RESET} TCP portuna gelen bağlantılara (Inbound Rules) izin vermeyi unutmayın.\n"
            echo -e "  Paneli durdurmak veya durumunu görmek için bu menüyü tekrar kullanabilirsiniz."
        else
            log_success "Web Dashboard successfully launched!"
            echo -e "\n  Open the dashboard in your browser using the links below:"
            echo -e "  - Local Link:    ${COLOR_CYAN}http://localhost:${active_port}${COLOR_RESET}"
            echo -e "  - Network Link:  ${COLOR_CYAN}http://${local_ip}:${active_port}${COLOR_RESET}"
            if [ -n "$dashboard_domain" ]; then
                echo -e "  - Domain Link:   ${COLOR_CYAN}http://${dashboard_domain}${COLOR_RESET}"
            fi
            echo -e "  - Access PIN (OTP Code): ${COLOR_GREEN}${otp_code}${COLOR_RESET}\n"
            echo -e "  ${COLOR_YELLOW}Note:${COLOR_RESET} If you are using a cloud provider (e.g. AWS, GCP, Hetzner, DigitalOcean),"
            echo -e "  please ensure that TCP port ${COLOR_GREEN}${active_port}${COLOR_RESET} is opened in your cloud firewall/security group.\n"
            echo -e "  You can return to this menu item at any time to stop or restart the dashboard."
        fi

        # Always prompt to bind/change domain on successful launch
        echo -e ""
        local prompt_launch_msg="Kontrol paneline bir domain (alan adı) bağlamak ister misiniz?"
        [ -n "$dashboard_domain" ] && prompt_launch_msg="Mevcut bağlı domain: ${COLOR_GREEN}${dashboard_domain}${COLOR_RESET}. Değiştirmek veya yeni bir domain bağlamak ister misiniz?"
        
        if [ "$LANG_PREF" = "tr" ]; then
            if prompt_yes_no "$prompt_launch_msg" "n"; then
                echo -n -e "  ${COLOR_CYAN}Lütfen bağlamak istediğiniz domain adını girin (Boş bırakırsanız mevcut domain kaldırılır):${COLOR_RESET} "
                local domain_input
                read -r domain_input
                bind_dashboard_domain "$domain_input"
            fi
        else
            local prompt_launch_msg_en="Would you like to bind a domain (subdomain) to this dashboard?"
            [ -n "$dashboard_domain" ] && prompt_launch_msg_en="Current bound domain: ${COLOR_GREEN}${dashboard_domain}${COLOR_RESET}. Would you like to change or bind a new one?"
            if prompt_yes_no "$prompt_launch_msg_en" "n"; then
                echo -n -e "  ${COLOR_CYAN}Please enter the domain name you want to bind (leave empty to remove existing domain):${COLOR_RESET} "
                local domain_input
                read -r domain_input
                bind_dashboard_domain "$domain_input"
            fi
        fi
    else
        if [ "$LANG_PREF" = "tr" ]; then
            log_error "Web paneli başlatılamadı! Lütfen günlükleri kontrol edin."
        else
            log_error "Failed to start Web Dashboard! Please check your logs."
        fi
    fi

    echo -e -n "\n  $(t "press_enter" "Press [Enter] to continue: ")"
    read -r _
}

check_for_updates() {
    local raw_script_url="https://raw.githubusercontent.com/devRaikou/mcserver-installer/main/mcserver-installer"

    # --- Semantic version comparison helper ---
    # Returns 0 if remote ($1) is strictly greater than local ($2)
    version_gt() {
        local remote="$1"
        local local_v="$2"
        [ "$remote" = "$local_v" ] && return 1
        local sorted
        sorted=$(printf '%s\n%s' "$remote" "$local_v" | sort -V 2>/dev/null | head -n 1)
        [ "$sorted" = "$local_v" ] && return 0
        return 1
    }

    # Try GitHub API first (lightweight, only fetches tag name)
    local latest=""
    local api_response
    api_response=$(curl -s -m 5 -H "$UA_HEADER" "https://api.github.com/repos/devRaikou/mcserver-installer/releases/latest" 2>/dev/null)

    if [ -n "$api_response" ]; then
        latest=$(echo "$api_response" | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | cut -d'"' -f4 | tr -d '[:space:]')
        # Strip leading 'v' if present (e.g. v1.28 -> 1.28)
        latest="${latest#v}"
    fi

    # Fallback: parse APP_VERSION from raw script if API failed
    if [ -z "$latest" ]; then
        latest=$(curl -s -m 5 -H "Cache-Control: no-cache" "${raw_script_url}?t=$(date +%s)" | grep -m 1 "^APP_VERSION=" | cut -d'"' -f2 | tr -d '[:space:]')
    fi

    # Only prompt if remote version is strictly greater than local
    if [ -n "$latest" ] && version_gt "$latest" "$APP_VERSION"; then
        clear_screen
        draw_header
        local update_choice="false"
        if [ "$LANG_PREF" = "tr" ]; then
            echo -e "  ${COLOR_YELLOW}================================================================${COLOR_RESET}"
            echo -e "  🚀 Yeni bir mcserver-installer sürümü mevcut: ${COLOR_GREEN}${latest}${COLOR_RESET} (Mevcut: ${APP_VERSION})"
            echo -e "  ${COLOR_YELLOW}================================================================${COLOR_RESET}\n"
            if prompt_yes_no "Otomatik olarak son sürüme güncellemek ister misiniz?" "y"; then update_choice="true"; fi
        else
            echo -e "  ${COLOR_YELLOW}================================================================${COLOR_RESET}"
            echo -e "  🚀 A new version of mcserver-installer is available: ${COLOR_GREEN}${latest}${COLOR_RESET} (Current: ${APP_VERSION})"
            echo -e "  ${COLOR_YELLOW}================================================================${COLOR_RESET}\n"
            if prompt_yes_no "Would you like to automatically update to the latest version?" "y"; then update_choice="true"; fi
        fi

        if [ "$update_choice" = "true" ]; then
            local temp_file="${SCRIPT_PATH}.tmp"
            if [ "$LANG_PREF" = "tr" ]; then
                run_with_spinner "Yeni sürüm indiriliyor" curl -s -L -H "Cache-Control: no-cache" -o "$temp_file" "${raw_script_url}?t=$(date +%s)"
            else
                run_with_spinner "Downloading new version" curl -s -L -H "Cache-Control: no-cache" -o "$temp_file" "${raw_script_url}?t=$(date +%s)"
            fi

            # Check shebang to ensure the downloaded file is a valid bash script
            if [ -f "$temp_file" ] && grep -q "#!/usr/bin/env bash" "$temp_file"; then
                # Sync other global versions of the script if they exist to prevent update loops
                local global_path; global_path=$(which mcserver-installer 2>/dev/null)
                if [ -n "$global_path" ] && [ "$global_path" != "$SCRIPT_PATH" ]; then
                    cp "$temp_file" "$global_path" 2>/dev/null && chmod +x "$global_path" 2>/dev/null
                fi

                if mv "$temp_file" "$SCRIPT_PATH" 2>/dev/null && chmod +x "$SCRIPT_PATH" 2>/dev/null; then
                    if [ "$LANG_PREF" = "tr" ]; then
                        log_success "mcserver-installer başarıyla güncellendi! Lütfen betiği yeniden başlatın."
                    else
                        log_success "mcserver-installer updated successfully! Please restart the script."
                    fi
                    exit 0
                else
                    rm -f "$temp_file"
                    if [ "$LANG_PREF" = "tr" ]; then
                        log_error "Güncelleme dosyası yazılamadı! Lütfen yazma izinlerini kontrol edin veya sudo ile çalıştırın."
                    else
                        log_error "Failed to write update file! Please check write permissions or run with sudo."
                    fi
                    sleep 4
                fi
            else
                rm -f "$temp_file"
                if [ "$LANG_PREF" = "tr" ]; then
                    log_error "Güncelleme dosyası doğrulanamadı veya bozuk indirildi!"
                else
                    log_error "Failed to validate update file or download corrupted!"
                fi
                sleep 3
            fi
        fi
    fi
}

