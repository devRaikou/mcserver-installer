remove_server_registration() {
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        log_warn "No installed servers registered."
        sleep 2
        return 1
    fi
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}DELETE SERVER / REGISTRATION${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    local servers=()
    local paths=()
    local list_options=()
    
    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        [ -z "$name" ] && continue
        servers+=("$name")
        paths+=("$path")
        list_options+=("$name - $path")
    done < "$REGISTRY_FILE"
    
    list_options+=("Cancel and Exit")
    local selection
    selection=$(prompt_selection "Choose server to delete:" "${list_options[@]}")
    
    if [ "$selection" = "Cancel and Exit" ]; then
        return 0
    fi
    
    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done
    
    if [ "$idx" -eq -1 ]; then return 0; fi
    
    local sel_name="${servers[$idx]}"
    local sel_path="${paths[$idx]}"
    local sess_name; sess_name=$(get_session_name "$sel_path")
    
    if is_server_running "$sess_name"; then
        log_error "The server is currently running. Please stop it first!"
        sleep 2
        return 1
    fi
    
    local delete_files="false"
    prompt_yes_no "Do you want to completely erase the files at ${sel_path}?" "n"
    [ $? -eq 0 ] && delete_files="true"
    
    # Remove from registry
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s|^.*:$sel_path:.*$||" "$REGISTRY_FILE"
    else
        sed -i "s|^.*:$sel_path:.*$||" "$REGISTRY_FILE"
    fi
    sed -i '/^[[:space:]]*$/d' "$REGISTRY_FILE"
    
    if [ "$delete_files" = "true" ]; then
        run_with_spinner "Deleting server files" rm -rf "$sel_path"
        log_success "Server and files deleted successfully."
    else
        log_success "Server registration removed from CLI, but files were kept."
    fi
    
    sleep 2
}

update_server_software() {
    if [ ! -f "$REGISTRY_FILE" ] || [ ! -s "$REGISTRY_FILE" ]; then
        log_warn "No installed servers registered."
        sleep 2
        return 1
    fi
    
    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}UPDATE SERVER SOFTWARE${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    
    local servers=()
    local paths=()
    local types=()
    local versions=()
    local list_options=()
    
    while IFS=":" read -r name path type version || [ -n "$name" ]; do
        [ -z "$name" ] && continue
        servers+=("$name")
        paths+=("$path")
        types+=("$type")
        versions+=("$version")
        list_options+=("$name ($type $version)")
    done < "$REGISTRY_FILE"
    
    list_options+=("Cancel and Exit")
    local selection
    selection=$(prompt_selection "Choose server to update:" "${list_options[@]}")
    
    if [ "$selection" = "Cancel and Exit" ]; then
        return 0
    fi
    
    local idx=-1
    for k in "${!list_options[@]}"; do
        if [ "${list_options[$k]}" = "$selection" ]; then
            idx=$k
            break
        fi
    done
    
    if [ "$idx" -eq -1 ]; then return 0; fi
    
    local s_path="${paths[$idx]}"
    local s_type="${types[$idx]}"
    local s_ver="${versions[$idx]}"
    local sess_name; sess_name=$(get_session_name "$s_path")
    
    if is_server_running "$sess_name"; then
        log_error "The server must be stopped before executing an update!"
        sleep 2
        return 1
    fi
    
    log_info "Fetching update options for $s_type..."
    local download_url=""
    
    case "$s_type" in
        vanilla)
            download_url=$(fetch_vanilla_download_url "$s_ver")
            ;;
        paper|folia|velocity|waterfall)
            local latest_build
            latest_build=$(fetch_papermc_builds "$s_type" "$s_ver" | sort -nr | head -n 1)
            log_info "Latest build resolved for $s_type $s_ver: Build $latest_build"
            download_url=$(fetch_papermc_download_url "$s_type" "$s_ver" "$latest_build")
            ;;
        purpur)
            download_url="https://api.purpurmc.org/v2/purpur/$s_ver/latest/download"
            ;;
        *)
            log_warn "Automatic in-place upgrades are not fully supported for modded configurations ($s_type)."
            log_warn "Please manually download the installer and update the jar files."
            sleep 3
            return 0
            ;;
    esac
    
    if [ -z "$download_url" ]; then
        log_error "Failed to resolve download URL."
        sleep 2
        return 1
    fi
    
    local jar_name="server.jar"
    [ "$s_type" = "velocity" ] && jar_name="velocity.jar"
    [ "$s_type" = "waterfall" ] && jar_name="waterfall.jar"
    [ "$s_type" = "purpur" ] && jar_name="purpur.jar"
    # Find matching jar or default to server.jar
    local dest_path="${s_path}/${jar_name}"
    
    download_file_with_progress "$download_url" "$dest_path" "updated $s_type jar"
    if [ $? -eq 0 ]; then
        log_success "Software updated successfully!"
    else
        log_error "Update failed."
    fi
    sleep 2
}

