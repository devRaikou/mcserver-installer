        echo -e "  Location: $prop_file"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
        
        # Read current configurations
        local port; port=$(get_property_val "$prop_file" "server-port")
        local motd; motd=$(get_property_val "$prop_file" "motd")
        local difficulty; difficulty=$(get_property_val "$prop_file" "difficulty")
        local gamemode; gamemode=$(get_property_val "$prop_file" "gamemode")
        local online; online=$(get_property_val "$prop_file" "online-mode")
        local pvp; pvp=$(get_property_val "$prop_file" "pvp")
        local whitelist; whitelist=$(get_property_val "$prop_file" "white-list")
        local players; players=$(get_property_val "$prop_file" "max-players")
        local flight; flight=$(get_property_val "$prop_file" "allow-flight")
