        echo -e "    ${COLOR_YELLOW}2.${COLOR_RESET} Online Mode       [${COLOR_GREEN}${online}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}3.${COLOR_RESET} MOTD              [${COLOR_GREEN}${motd}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}4.${COLOR_RESET} Max Players       [${COLOR_GREEN}${players}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}5.${COLOR_RESET} Difficulty        [${COLOR_GREEN}${difficulty}${COLOR_RESET}]"
