send_discord_notification() {
    local msg="$1"
    local color="${2:-3066993}"
    local server_path="${3:-}"
    local extra_field_name="${4:-}"
    local extra_field_val="${5:-}"
    
    local settings_file="${HOME}/.mcserver-installer/settings.conf"
    if [ -f "$settings_file" ]; then
        local webhook
        webhook=$(grep '^DISCORD_WEBHOOK=' "$settings_file" | cut -d'"' -f2 | tr -d '\r')
        if [ -n "$webhook" ]; then
            local s_name="Unknown"
            local s_type="Unknown"
            local s_ver="Unknown"
            local local_ip="Unknown"
            local public_ip="Unknown"
            local port="Unknown"
            
            if [ -n "$server_path" ] && [ -f "$REGISTRY_FILE" ]; then
                local abs_target
                abs_target=$(cd "$server_path" 2>/dev/null && pwd -P || echo "$server_path")
                
                while IFS=":" read -r r_name r_path r_type r_ver || [ -n "$r_name" ]; do
                    [ -z "$r_name" ] && continue
                    local abs_reg
                    abs_reg=$(cd "$r_path" 2>/dev/null && pwd -P || echo "$r_path")
                    if [ "$abs_target" = "$abs_reg" ]; then
                        s_name="$r_name"
                        s_type="$r_type"
                        s_ver="$r_ver"
                        local_ip=$(get_local_ip)
                        public_ip=$(cat "${HOME}/.mcserver-installer/.public_ip" 2>/dev/null || echo "Unknown")
                        [ -z "$public_ip" ] && public_ip="Unknown"
                        port=$(get_server_port "$r_path" "$s_type")
                        break
                    fi
                done < "$REGISTRY_FILE"
            fi
            
            local fields_json=""
            if [ "$s_name" != "Unknown" ]; then
                fields_json=", \"fields\": [
                    { \"name\": \"Server Name\", \"value\": \"${s_name}\", \"inline\": true },
                    { \"name\": \"Software & Version\", \"value\": \"${s_type} (${s_ver})\", \"inline\": true },
                    { \"name\": \"Connection Address\", \"value\": \"\`${public_ip}:${port}\` (Public)\\n\`${local_ip}:${port}\` (Local)\", \"inline\": false }"
                    
                if [ -n "$extra_field_name" ] && [ -n "$extra_field_val" ]; then
                    fields_json="${fields_json}, { \"name\": \"${extra_field_name}\", \"value\": \"${extra_field_val}\", \"inline\": true }"
                fi
                fields_json="${fields_json} ]"
            elif [ -n "$extra_field_name" ] && [ -n "$extra_field_val" ]; then
                fields_json=", \"fields\": [ { \"name\": \"${extra_field_name}\", \"value\": \"${extra_field_val}\", \"inline\": true } ]"
            fi
            
            local clean_msg
            clean_msg=$(echo "$msg" | sed 's/"/\\"/g')
            
            (
                curl -s -H "Content-Type: application/json" \
                     -X POST \
                     -d "{\"embeds\": [{\"title\": \"🖥️ mcserver-installer Notification\", \"description\": \"${clean_msg}\", \"color\": ${color} ${fields_json}, \"footer\": {\"text\": \"devRaikou mcserver-installer | GitHub: https://github.com/devRaikou/mcserver-installer\"}, \"timestamp\": \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"}]}" \
                     "$webhook" >/dev/null 2>&1
            ) &
        fi
    fi
}

