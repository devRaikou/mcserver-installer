import_pterodactyl() {
    local tarball="$1"
    local srv_name="$2"
    if [ -z "$tarball" ] || [ -z "$srv_name" ]; then
        echo "Usage: --import-ptero <tarball_path> <new_server_name>" >&2
        return 1
    fi
    if [ ! -f "$tarball" ]; then
        echo "Error: Archive not found at $tarball" >&2
        return 1
    fi
    srv_name=$(echo "$srv_name" | tr -cd 'a-zA-Z0-9_-')
    local srv_path="${HOME}/minecraft/$srv_name"
    if [ -d "$srv_path" ]; then
        echo "Error: Server directory $srv_path already exists." >&2
        return 1
    fi
    mkdir -p "$srv_path"
    echo "Extracting archive to $srv_path..."
    tar -xzf "$tarball" -C "$srv_path" || { echo "Error extracting archive"; rm -rf "$srv_path"; return 1; }
    
    local port="25565"
    if [ -f "$srv_path/server.properties" ]; then
        local extracted_port
        extracted_port=$(grep "^server-port=" "$srv_path/server.properties" | cut -d= -f2 | tr -d '\r')
        [ -n "$extracted_port" ] && port="$extracted_port"
    fi
    
    local srv_type="vanilla"
    if [ -f "$srv_path/velocity.jar" ]; then srv_type="velocity";
    elif [ -f "$srv_path/bungeecord.jar" ] || [ -f "$srv_path/waterfall.jar" ]; then srv_type="waterfall";
    elif [ -f "$srv_path/purpur.jar" ]; then srv_type="purpur";
    elif ls "$srv_path"/*.jar 1> /dev/null 2>&1; then srv_type="paper"; fi
    
    if [ ! -f "$srv_path/start.sh" ]; then
        local jar_name="server.jar"
        if ls "$srv_path"/*.jar 1> /dev/null 2>&1; then jar_name=$(ls "$srv_path"/*.jar | head -n 1 | awk -F/ '{print $NF}'); fi
        cat > "$srv_path/start.sh" <<EOF
#!/bin/bash
java -Xms1G -Xmx2G -jar $jar_name nogui
EOF
        chmod +x "$srv_path/start.sh"
    fi
    
    echo "${srv_name}:${srv_path}:${srv_type}:imported" >> "$REGISTRY_FILE"
    echo "Successfully imported Pterodactyl backup '$srv_name' (Type: $srv_type, Port: $port)."
}

build_proxy_network() {
    local net_name="$1"
    local proxy_port="$2"
    local proxy_sw="${3:-velocity}"
    local proxy_ver="$4"
    local backend_sw="${5:-paper}"
    local backend_ver="$6"
    local backend_names_csv="${7:-lobby,survival}"
    local ram="${8:-2G}"

    if [ -z "$net_name" ] || [ -z "$proxy_port" ]; then
        echo "Usage: --build-network <net_name> <proxy_port> [proxy_sw] [proxy_ver] [backend_sw] [backend_ver] [backend_names] [ram]" >&2
        return 1
    fi

    # Resolve proxy version if not provided
    if [ -z "$proxy_ver" ]; then
        echo "Resolving latest ${proxy_sw} version..."
        proxy_ver=$(fetch_papermc_versions "$proxy_sw" | tail -n 1)
        if [ -z "$proxy_ver" ]; then
            echo "Error: Could not resolve latest ${proxy_sw} version." >&2
            return 1
        fi
    fi

    # Resolve backend version if not provided
    if [ -z "$backend_ver" ]; then
        echo "Resolving latest ${backend_sw} version..."
        backend_ver=$(fetch_papermc_versions "$backend_sw" | tail -n 1)
        if [ -z "$backend_ver" ]; then
            echo "Error: Could not resolve latest ${backend_sw} version." >&2
            return 1
        fi
    fi

    local proxy_name="${net_name}-proxy"
    echo "Building Proxy Network '$net_name' starting at port $proxy_port..."
    echo "  Proxy: ${proxy_sw} ${proxy_ver}"
    echo "  Backend: ${backend_sw} ${backend_ver}"

    # Install proxy
    echo "Installing Proxy (${proxy_name})..."
    headless_install_server "$proxy_name" "$proxy_sw" "$proxy_ver" "$proxy_port" "1"

    # Parse backend names and install each
    local IFS=','
    local backend_list=()
    read -ra backend_list <<< "$backend_names_csv"
    unset IFS

    local current_port=$((proxy_port + 1))
    local all_members="${proxy_name}"
    local velocity_servers=""
    local first_backend=""

    for bname_port in "${backend_list[@]}"; do
        local bname="${bname_port%%:*}"
        local bport="${bname_port##*:}"
        # If no port provided (they are equal), fallback to current_port
        if [ "$bname" = "$bport" ]; then
            bport=$current_port
            current_port=$((current_port + 1))
        fi
        
        bname=$(echo "$bname" | tr -cd 'a-zA-Z0-9_-')
        [ -z "$bname" ] && continue
        local full_name="${net_name}-${bname}"
        echo "Installing Backend (${full_name}) on port ${bport}..."
        headless_install_server "$full_name" "$backend_sw" "$backend_ver" "$bport" "$ram"
        all_members="${all_members},${full_name}"
        velocity_servers="${velocity_servers}${bname} = \"127.0.0.1:${bport}\"\n"
        [ -z "$first_backend" ] && first_backend="$bname"
    done

    # Configure proxy
    local proxy_dir="${HOME}/minecraft/${proxy_name}"
    if [ "$proxy_sw" = "velocity" ]; then
        if [ -f "$proxy_dir/velocity.toml" ]; then
            INS="$(echo -e "$velocity_servers\ntry = [\"${first_backend}\"]")" awk '/^\[servers\]/{print; print ENVIRON["INS"]; next}1' "$proxy_dir/velocity.toml" > "$proxy_dir/tmp.toml" && mv "$proxy_dir/tmp.toml" "$proxy_dir/velocity.toml"
        else
            mkdir -p "$proxy_dir"
            cat > "$proxy_dir/velocity.toml" <<EOF
[servers]
$(echo -e "$velocity_servers")
try = ["${first_backend}"]
[advanced]
bungee-plugin-message-channel = true
EOF
        fi
    elif [ "$proxy_sw" = "waterfall" ] || [ "$proxy_sw" = "bungeecord" ]; then
        if [ -f "$proxy_dir/config.yml" ]; then
            echo "# Backend servers added by build-network" >> "$proxy_dir/config.yml"
        fi
    fi

    # Save network metadata
    local meta_dir="${HOME}/.mcserver-installer"
    mkdir -p "$meta_dir"
    echo "${net_name}:${all_members}" >> "$meta_dir/networks.txt"

    echo "Network '$net_name' built successfully with servers: ${all_members}"
}

headless_install_server() {
    local name="$1"
    local software="$2"
    local version="$3"
    local port="$4"
    local ram="$5"
    local backend_names="${6:-}"
    local backend_version="${7:-}"

    if [ -z "$name" ] || [ -z "$software" ] || [ -z "$version" ] || [ -z "$port" ] || [ -z "$ram" ]; then
        echo "Error: Missing arguments." >&2
        echo "Usage: --install <name> <software> <version> <port> <ram>" >&2
        return 1
    fi

    # Clean name
    name=$(echo "$name" | tr -cd 'a-zA-Z0-9_-')
    if [ -z "$name" ]; then
        echo "Error: Invalid server name." >&2
        return 1
    fi

    # Check duplicates in registry
    if [ -f "$REGISTRY_FILE" ] && grep -q "^${name}:" "$REGISTRY_FILE"; then
        echo "Error: Server with name '${name}' already exists in registry." >&2
        return 1
    fi

    # Create target directory
    local inst_dir="${HOME}/minecraft/${name}"
    if [ -d "$inst_dir" ]; then
        echo "Error: Directory '${inst_dir}' already exists." >&2
        return 1
    fi

    mkdir -p "$inst_dir"
    cd "$inst_dir" || { echo "Error: Cannot enter folder ${inst_dir}." >&2; return 1; }

    # Resolve download url
    local download_url=""
    local build_num=""
    local s_type=$(echo "$software" | tr '[:upper:]' '[:lower:]')

    case "$s_type" in
        vanilla)
            download_url=$(fetch_vanilla_download_url "$version")
            ;;
        paper|folia|velocity|waterfall)
            local builds
            builds=$(fetch_papermc_builds "$s_type" "$version" | sort -nr)
            build_num=$(echo "$builds" | head -n 1)
            if [ -n "$build_num" ]; then
                download_url=$(fetch_papermc_download_url "$s_type" "$version" "$build_num")
            fi
            ;;
        purpur)
            download_url="https://api.purpurmc.org/v2/purpur/${version}/latest/download"
            ;;
        *)
            echo "Error: Headless installation only supports Vanilla, Paper, Folia, Purpur, Velocity, and Waterfall currently." >&2
            cd "${HOME}" && rm -rf "$inst_dir"
            return 1
            ;;
    esac

    if [ -z "$download_url" ] || [ "$download_url" = "null" ]; then
        echo "Error: Could not resolve download URL for ${software} ${version}." >&2
        cd "${HOME}" && rm -rf "$inst_dir"
        return 1
    fi

    # Download JAR
    local jar_file="server.jar"
    if [ "$s_type" = "velocity" ]; then
        jar_file="velocity.jar"
    elif [ "$s_type" = "waterfall" ]; then
        jar_file="waterfall.jar"
    elif [ "$s_type" = "bungeecord" ]; then
        jar_file="bungeecord.jar"
    fi

    echo "Downloading ${software} ${version} jar file..."
    if ! curl -s -L -o "$jar_file" "$download_url"; then
        echo "Error: Failed to download JAR from ${download_url}." >&2
        cd "${HOME}" && rm -rf "$inst_dir"
        return 1
    fi

    # Create EULA
    echo "eula=true" > eula.txt

    # Configs
    if [ "$s_type" = "velocity" ]; then
        cat <<EOF > velocity.toml
[servers]
[forced-hosts]
[advanced]
[query]
enabled = true
port = ${port}
EOF
    elif [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
        cat <<EOF > config.yml
listeners:
- query_port: ${port}
  host: 0.0.0.0:${port}
  query_enabled: true
EOF
    else
        cat <<EOF > server.properties
#Minecraft server properties
enable-jmx-monitoring=false
rcon.port=25575
level-seed=
gamemode=survival
enable-command-block=false
enable-query=true
generator-settings={}
enforce-secure-profile=true
level-name=world
motd=A Minecraft Server Installed via Web Dashboard
query.port=${port}
pvp=true
generate-structures=true
max-chained-neighbor-updates=10000
difficulty=easy
network-compression-threshold=256
max-tick-time=60000
require-resource-pack=false
use-native-transport=true
max-players=20
online-mode=false
enable-status=true
allow-flight=false
initial-disabled-packs=
broadcast-rcon-to-ops=true
view-distance=10
server-ip=
resource-pack-prompt=
allow-nether=true
server-port=${port}
enable-rcon=false
sync-chunk-writes=true
op-permission-level=4
prevent-proxy-connections=false
hide-online-players=false
resource-pack=
entity-broadcast-range-percentage=100
simulation-distance=10
rcon.password=
player-idle-timeout=0
force-gamemode=false
rate-limit=0
hardcore=false
white-list=false
broadcast-console-to-ops=true
spawn-npcs=true
spawn-animals=true
function-permission-level=2
initial-enabled-packs=vanilla
level-type=minecraft\:normal
text-filtering-config=
spawn-monsters=true
enforce-whitelist=false
spawn-protection=16
resource-pack-sha1=
max-world-size=29999984
EOF
    fi

    # Java JRE resolution
    local java_ver=17
    if [[ "$version" =~ ^1\.(20\.[5-9]|2[1-9]) ]]; then
        java_ver=21
    elif [[ "$version" =~ ^1\.(18|19|20) ]]; then
        java_ver=17
    elif [[ "$version" =~ ^1\.(16|17) ]]; then
        java_ver=16
    elif [[ "$version" =~ ^1\.(8|9|10|11|12|13|14|15) ]]; then
        java_ver=8
    fi

    local resolved_java="java"
    if [ -n "$(find_java_binary_path "$java_ver")" ]; then
        resolved_java=$(find_java_binary_path "$java_ver")
    else
        install_java_package "$java_ver" &>/dev/null
        if [ -n "$(find_java_binary_path "$java_ver")" ]; then
            resolved_java=$(find_java_binary_path "$java_ver")
        fi
    fi

    # Build start.sh
    cat <<EOF > start.sh
#!/usr/bin/env bash
MEM_MIN="${ram}"
MEM_MAX="${ram}"

cd "\$(dirname "\$0")"

while [ ! -f .stop_restart ]; do
    echo "[mcserver-installer] Starting Minecraft server..."
    "${resolved_java}" -Xms"\${MEM_MIN}" -Xmx"\${MEM_MAX}" -jar ${jar_file} nogui
    if [ -f .stop_restart ]; then
        break
    fi
    echo "[mcserver-installer] Server stopped. Restarting in 5 seconds..."
    sleep 5
done
rm -f .stop_restart
EOF
    chmod +x start.sh

    # Save to registry
    echo "${name}:${inst_dir}:${s_type}:${version}" >> "$REGISTRY_FILE"

    # Firewall
    if command -v ufw &>/dev/null; then
        if sudo ufw status 2>/dev/null | grep -q "Status: active"; then
            sudo ufw allow "${port}/tcp" &>/dev/null
            sudo ufw allow "${port}/udp" &>/dev/null
        fi
    fi

    # Run backend orchestrator if proxy server software was installed
    if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
        if [ -n "$backend_names" ] && [ -n "$backend_version" ]; then
            headless_orchestrate_proxy_network "$inst_dir" "$name" "$s_type" "$port" "$backend_names" "$backend_version"
        fi
    fi

    # Start Minecraft Server
    if ! start_minecraft_server "$inst_dir" &>/dev/null; then
        echo "Warning: Server installed but failed to start automatically." >&2
    fi
    echo "SUCCESS: Server '${name}' successfully installed to '${inst_dir}' and started on port ${port}."
    return 0
}

bind_dashboard_domain() {
    local domain="$1"

    if [ -z "$domain" ]; then
        # Remove existing domain
        local existing_domain=""
        if [ -f "$SETTINGS_FILE" ]; then
            existing_domain=$(grep '^DASHBOARD_DOMAIN=' "$SETTINGS_FILE" | cut -d'"' -f2 | tr -d '\r' || true)
        fi
        if [ -n "$existing_domain" ]; then
            sudo rm -f "/etc/nginx/sites-available/${existing_domain}"
            sudo rm -f "/etc/nginx/sites-enabled/${existing_domain}"
            if command -v systemctl &>/dev/null; then
                sudo systemctl reload nginx &>/dev/null
            else
                sudo service nginx reload &>/dev/null
            fi
            # Remove from settings.conf
            if [[ "$OSTYPE" == "darwin"* ]]; then
                sed -i '' '/^DASHBOARD_DOMAIN=/d' "$SETTINGS_FILE"
            else
                sed -i '/^DASHBOARD_DOMAIN=/d' "$SETTINGS_FILE"
            fi
            if [ "$LANG_PREF" = "tr" ]; then
                log_success "BAŞARILI: Mevcut domain (${existing_domain}) kaldırıldı."
            else
                log_success "SUCCESS: Existing domain (${existing_domain}) has been removed."
            fi
        else
            if [ "$LANG_PREF" = "tr" ]; then
                log_error "Hata: Bağlanacak veya kaldırılacak bir domain belirtilmedi."
            else
                log_error "Error: No domain specified to bind or remove."
            fi
        fi
        return 0
    fi

    if ! command -v nginx &>/dev/null; then
        if [ "$LANG_PREF" = "tr" ]; then
            echo "Nginx kurulu değil. Nginx yükleniyor..."
        else
            echo "Nginx is not installed. Installing nginx..."
        fi
        if command -v apt-get &>/dev/null; then
            sudo apt-get update &>/dev/null
            sudo apt-get install -y nginx &>/dev/null
        else
            echo "Error: Nginx not found and package manager apt-get not available." >&2
            return 1
        fi
    fi

    local port="3000"
    if [ -f "${CONFIG_DIR}/.dashboard_port" ]; then
        port=$(cat "${CONFIG_DIR}/.dashboard_port" | tr -d '[:space:]')
    fi

    local conf_file="/etc/nginx/sites-available/${domain}"
    
    sudo bash -c "cat <<EOF > '${conf_file}'
server {
    listen 80;
    server_name ${domain};

    location / {
        proxy_pass http://127.0.0.1:${port};
        proxy_http_version 1.1;
        proxy_set_header Upgrade \\\$http_upgrade;
        proxy_set_header Connection \"upgrade\";
        proxy_set_header Host \\\$host;
        proxy_set_header X-Real-IP \\\$remote_addr;
        proxy_set_header X-Forwarded-For \\\$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \\\$scheme;
    }
}
EOF"

    sudo ln -sf "${conf_file}" "/etc/nginx/sites-enabled/"
    sudo rm -f "/etc/nginx/sites-enabled/default"

    if ! sudo nginx -t &>/dev/null; then
        echo "Error: Nginx configuration test failed!" >&2
        sudo rm -f "/etc/nginx/sites-enabled/${domain}"
        sudo rm -f "${conf_file}"
        return 1
    fi

    if command -v systemctl &>/dev/null; then
        sudo systemctl reload nginx &>/dev/null
    else
        sudo service nginx reload &>/dev/null
    fi

    if command -v ufw &>/dev/null; then
        if sudo ufw status 2>/dev/null | grep -q "Status: active"; then
            sudo ufw allow 80/tcp &>/dev/null
            sudo ufw allow 443/tcp &>/dev/null
        fi
    fi

    if [ -f "$SETTINGS_FILE" ]; then
        if grep -q "^DASHBOARD_DOMAIN=" "$SETTINGS_FILE"; then
            if [[ "$OSTYPE" == "darwin"* ]]; then
                sed -i '' "s|^DASHBOARD_DOMAIN=.*|DASHBOARD_DOMAIN=\"${domain}\"|" "$SETTINGS_FILE"
            else
                sed -i "s|^DASHBOARD_DOMAIN=.*|DASHBOARD_DOMAIN=\"${domain}\"|" "$SETTINGS_FILE"
            fi
        else
            echo "DASHBOARD_DOMAIN=\"${domain}\"" >> "$SETTINGS_FILE"
        fi
    fi

    # Fetch Server Public IP
    local public_ip="127.0.0.1"
    if command -v hostname &>/dev/null; then
        public_ip=$(hostname -I | awk '{print $1}')
    fi
    if [ -z "$public_ip" ]; then
        public_ip=$(ip route get 1 2>/dev/null | awk '{print $7}')
    fi
    if [ -z "$public_ip" ]; then
        public_ip=$(ifconfig | grep "inet " | grep -v "127.0.0.1" | awk '{print $2}' | head -n 1)
    fi
    [ -z "$public_ip" ] && public_ip="127.0.0.1"

    # Extract host prefix
    local host_part="@"
    local dots
    dots=$(echo "$domain" | tr -cd '.' | wc -c)
    if [ "$dots" -ge 2 ]; then
        host_part=$(echo "$domain" | cut -d'.' -f1)
    fi

    if [ "$LANG_PREF" = "tr" ]; then
        log_success "BAŞARILI: ${domain} adresi port ${port} üzerindeki Web Paneline başarıyla bağlandı!"
        echo -e "\n  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        echo -e "  ${COLOR_GREEN}DNS YAPILANDIRMASI${COLOR_RESET}"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        echo -e "  Alan adınızın bu sunucuya yönlenmesi için DNS sağlayıcınızda"
        echo -e "  (Cloudflare, GoDaddy, Namecheap vb.) aşağıdaki DNS kaydını oluşturun:"
        echo -e ""
        echo -e "  Tür          | İsim (Host)         | Değer (IP)"
        echo -e "  -------------|---------------------|------------------"
        echo -e "  A            | ${COLOR_GREEN}${host_part}${COLOR_RESET}                  | ${COLOR_YELLOW}${public_ip}${COLOR_RESET}"
        echo -e "  -------------|---------------------|------------------"
        echo -e ""
        echo -e "  * ${COLOR_YELLOW}Not:${COLOR_RESET} Cloudflare kullanılıyorsa 'Proxy' bulutu kapatılıp (DNS Only) yapılması önerilir."
        echo -e "    Eğer '${domain}' gibi bir alt alan adı yönlendiriyorsanız Host kısmına '${COLOR_GREEN}${host_part}${COLOR_RESET}' yazın."
        echo -e "    Eğer ana alan adını yönlendiriyorsanız Host kısmına '${COLOR_GREEN}@${COLOR_RESET}' yazın."
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    else
        log_success "SUCCESS: Domain ${domain} successfully bound to Web Dashboard on port ${port}!"
        echo -e "\n  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        echo -e "  ${COLOR_GREEN}DNS CONFIGURATION${COLOR_RESET}"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"
        echo -e "  To point your domain to this server, create the following DNS record"
        echo -e "  in your DNS provider (Cloudflare, GoDaddy, Namecheap, etc.):"
        echo -e ""
        echo -e "  Type         | Name (Host)         | Value (IP)"
        echo -e "  -------------|---------------------|------------------"
        echo -e "  A            | ${COLOR_GREEN}${host_part}${COLOR_RESET}                  | ${COLOR_YELLOW}${public_ip}${COLOR_RESET}"
        echo -e "  -------------|---------------------|------------------"
        echo -e ""
        echo -e "  * ${COLOR_YELLOW}Note:${COLOR_RESET} It is recommended to turn off Proxy (DNS Only) on Cloudflare."
        echo -e "    If you point a subdomain like '${domain}', write '${COLOR_GREEN}${host_part}${COLOR_RESET}' in Name/Host."
        echo -e "    If you point the root domain directly, write '${COLOR_GREEN}@${COLOR_RESET}' in Name/Host."
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    fi
    return 0
}

# --- Command Line Argument Parser (Headless Execution) ---
if [ $# -gt 0 ]; then
    if [ "$1" = "--backup" ]; then
        if [ $# -lt 2 ]; then
            echo "Usage: $0 --backup <server_name>" >&2
            exit 1
        fi

        HEADLESS_MODE="true"
        target_name="$2"
        if [ -f "$REGISTRY_FILE" ]; then
            line=""
            while IFS=":" read -r r_name r_path r_type r_ver || [ -n "$r_name" ]; do
                if [ "$r_name" = "$target_name" ]; then
                    line="${r_name}:${r_path}:${r_type}:${r_ver}"
                    break
                fi
            done < "$REGISTRY_FILE"
            if [ -n "$line" ]; then
                s_path=$(echo "$line" | cut -d: -f2)
                create_server_backup "$s_path"
                exit $?
            else
                echo "Error: Server '${target_name}' not found in registry." >&2
                exit 1
            fi
        else
            echo "Error: Registry file is empty or does not exist." >&2
            exit 1
        fi
    elif [ "$1" = "--get-versions" ]; then
        if [ $# -lt 2 ]; then
            echo "Usage: $0 --get-versions <vanilla|paper|purpur|velocity|folia|waterfall>" >&2
            exit 1
        fi
        HEADLESS_MODE="true"
        s_type="$2"
        case "$s_type" in
            vanilla)
                fetch_vanilla_releases
                ;;
            paper|folia|velocity|waterfall)
                fetch_papermc_versions "$s_type"
                ;;
            purpur)
                fetch_purpur_versions
                ;;
            *)
                echo "Unsupported software: $s_type" >&2
                exit 1
                ;;
        esac
        exit 0
    elif [ "$1" = "--install" ]; then
        if [ $# -lt 6 ]; then
            echo "Usage: $0 --install <name> <software> <version> <port> <ram> [backend_names] [backend_version]" >&2
            exit 1
        fi
        HEADLESS_MODE="true"
        headless_install_server "$2" "$3" "$4" "$5" "$6" "${7:-}" "${8:-}"
        exit $?
    elif [ "$1" = "--bind-domain" ]; then
        if [ $# -lt 2 ]; then
            echo "Usage: $0 --bind-domain <domain>" >&2
            exit 1
        fi
        HEADLESS_MODE="true"
        bind_dashboard_domain "$2"
        exit $?
    elif [ "$1" = "--import-ptero" ]; then
        HEADLESS_MODE="true"
        import_pterodactyl "$2" "$3"
        exit $?
    elif [ "$1" = "--build-network" ]; then
        HEADLESS_MODE="true"
        build_proxy_network "$2" "$3" "${4:-}" "${5:-}" "${6:-}" "${7:-}" "${8:-}" "${9:-}"
        exit $?
    else
        echo "Unknown argument: $1" >&2
        echo "Usage: $0 [--backup <server_name>] [--get-versions <software>] [--install <name> <software> <version> <port> <ram>] [--bind-domain <domain>] [--import-ptero <tarball> <name>] [--build-network <net_name> <proxy_port>]" >&2
        exit 1
    fi
fi

# Launch Application
HEADLESS_MODE="false"
check_for_updates
main_menu
