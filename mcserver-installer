    fi

    # 4. Installation Directory
    local default_dir="${HOME}/MinecraftServer"
    local inst_dir
    while true; do
        if [ "$LANG_PREF" = "tr" ]; then
            inst_dir=$(prompt_input "Kurulum dizinini girin" "$default_dir")
        else
            inst_dir=$(prompt_input "Enter installation directory" "$default_dir")
        fi

        # Expand tilde if present
        inst_dir="${inst_dir/#\~/$HOME}"

        # Resolve relative paths to absolute path
        if [[ "$inst_dir" != /* ]]; then
            inst_dir="$(pwd)/${inst_dir}"
        fi

        local candidate_name
        candidate_name=$(basename "$inst_dir")
        if [ -z "$candidate_name" ] || ! is_registry_safe_value "$candidate_name" || ! is_registry_safe_value "$inst_dir"; then
            log_warn "Installation path and server name cannot be empty or contain ':' characters."
            continue
        fi
        break
    done

    if [ -d "$inst_dir" ] && [ "$(ls -A "$inst_dir" 2>/dev/null)" ]; then
        log_warn "Directory $inst_dir exists and is NOT empty."
        if ! prompt_yes_no "Do you want to overwrite files in this directory?" "n"; then
            log_error "Installation canceled."
            exit 1
        fi
    fi

    # 5. RAM Selection
    local min_ram
    local max_ram
    min_ram=$(prompt_ram_input "Enter Minimum RAM allocation (e.g., 1024M, 2G)" "1024M")
    max_ram=$(prompt_ram_input "Enter Maximum RAM allocation (e.g., 4096M, 4G)" "4096M")

    # 6. Java Detection & Required Java configuration
    local required_java
    required_java=$(get_required_java_version "$mc_version" "$s_type")

    verify_or_install_java "$required_java"
    if [ $? -ne 0 ]; then
        log_error "Java setup failed. Cannot continue."
        exit 1
    fi

    local java_path
    java_path=$(find_java_binary_path "$required_java")


    # 7. Port check
    local default_port="25565"
    if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
        default_port="25577"
    fi

    local port
    while true; do
        if [ "$LANG_PREF" = "tr" ]; then
            port=$(prompt_port_input "Sunucu portunu girin" "$default_port")
        else
            port=$(prompt_port_input "Enter server port" "$default_port")
        fi

        # Check active port binding
        if command -v ss &>/dev/null; then
            if ss -tuln | grep -q ":${port} "; then
                if [ "$LANG_PREF" = "tr" ]; then
                    log_warn "Port $port şu anda kullanımda. Lütfen başka bir port seçin."
                else
                    log_warn "Port $port is currently in use. Please select a different port."
                fi
                continue
            fi
        fi

        # Check registered servers' ports
        if is_port_taken_by_registered_servers "$port"; then
            if [ "$LANG_PREF" = "tr" ]; then
                log_warn "Port $port zaten kayıtlı başka bir sunucu tarafından kullanılıyor. Lütfen başka bir port seçin."
            else
                log_warn "Port $port is already allocated to another registered server. Please select a different port."
            fi
            continue
        fi
        break
    done

    # Check if proxy type to skip gameplay questions
    local online_mode="true"
    local motd="A Minecraft Server"
    local max_players="20"
    local difficulty="normal"
    local gamemode="survival"
    local world_name="world"

    if [ "$s_type" != "velocity" ] && [ "$s_type" != "waterfall" ] && [ "$s_type" != "bungeecord" ]; then
        # 8. Online Mode
        online_mode="true"
        if ! prompt_yes_no "Enable Online Mode (authenticate accounts via Mojang)?" "y"; then online_mode="false"; fi

        # 9. MOTD
        motd=$(prompt_input "Enter Server MOTD" "Welcome to our devRaikou Server!")

        # 10. Max Players
        max_players=$(prompt_input "Enter Max Players" "20")

        # 11. Difficulty
        local diff_options=(peaceful easy normal hard "$back_opt")
        difficulty=$(prompt_selection "$(t "prompt_difficulty" "Select Difficulty:")" "${diff_options[@]}")
        if [ "$difficulty" = "$back_opt" ] || [ -z "$difficulty" ]; then
            rm -rf "$TMP_WIZARD_DIR" 2>/dev/null
            return 0
        fi

        # 12. GameMode
        local gm_options=(survival creative adventure spectator "$back_opt")
        gamemode=$(prompt_selection "$(t "prompt_gamemode" "Select Default GameMode:")" "${gm_options[@]}")
        if [ "$gamemode" = "$back_opt" ] || [ -z "$gamemode" ]; then
            rm -rf "$TMP_WIZARD_DIR" 2>/dev/null
            return 0
        fi

        # 13. World Name
        world_name=$(prompt_input "Enter World Name" "world")
    fi

    # 14. EULA acceptance check
    if ! prompt_yes_no "Do you agree to Mojang's EULA (https://account.mojang.com/documents/minecraft_eula)?" "y"; then
        log_error "You must agree to the EULA to install the server."
        exit 1
    fi

    # --- Perform Installation Actions ---
    mkdir -p "$inst_dir"
    cd "$inst_dir" || { log_error "Failed to enter installation folder."; exit 1; }

    # Download the main jar/installer file
    local jar_dest="server.jar"
    if [ "$s_type" = "fabric" ] || [ "$s_type" = "forge" ] || [ "$s_type" = "neoforge" ]; then
        jar_dest="installer.jar"
    fi

    download_file_with_progress "$download_url" "$jar_dest" "$s_type jar"
    if [ $? -ne 0 ]; then
        log_error "Failed to download server file."
        exit 1
    fi

    # If Modded installer, run installServer
    local final_jar="server.jar"
    if [ "$s_type" = "fabric" ]; then
        run_with_spinner "Extracting Fabric server resources" java -jar installer.jar server -mcversion "$mc_version" -loader "$loader_version" -downloadMinecraft
        if [ $? -ne 0 ]; then
            log_error "Fabric server installation failed."
            exit 1
        fi
        final_jar="fabric-server-launch.jar"
        rm -f installer.jar
    elif [ "$s_type" = "forge" ]; then
        run_with_spinner "Installing Forge server dependencies (may take a few minutes)" java -jar installer.jar --installServer
        if [ $? -ne 0 ]; then
            log_error "Forge server installation failed."
            exit 1
        fi
        # Locate forge run script or jar
        if [ -f run.sh ]; then
            # Modern Forge (1.17+) does not run jar directly, it uses a generated run.sh
            final_jar="FORGE_RUN_SCRIPT"
        else
            # Older Forge uses forge-<version>.jar
            final_jar=$(ls forge-*.jar | head -n 1)
        fi
        rm -f installer.jar installer.jar.log
    elif [ "$s_type" = "neoforge" ]; then
        run_with_spinner "Installing NeoForge server dependencies (may take a few minutes)" java -jar installer.jar --installServer
        if [ $? -ne 0 ]; then
            log_error "NeoForge server installation failed."
            exit 1
        fi
        final_jar="NEOFORGE_RUN_SCRIPT"
        rm -f installer.jar installer.jar.log
    elif [ "$s_type" = "velocity" ]; then
        final_jar="velocity.jar"
        mv server.jar velocity.jar
    elif [ "$s_type" = "waterfall" ]; then
        final_jar="waterfall.jar"
        mv server.jar waterfall.jar
    fi

    # Save EULA
    echo "eula=true" > eula.txt

    # Save properties (if not proxy)
    if [ "$s_type" != "velocity" ] && [ "$s_type" != "waterfall" ] && [ "$s_type" != "bungeecord" ]; then
        cat <<EOF > server.properties
#Minecraft server properties
enable-jmx-monitoring=false
rcon.port=25575
level-seed=
gamemode=${gamemode}
enable-command-block=false
enable-query=true
generator-settings={}
enforce-secure-profile=true
level-name=${world_name}
motd=${motd}
query.port=${port}
pvp=true
generate-structures=true
max-chained-neighbor-updates=10000
difficulty=${difficulty}
network-compression-threshold=256
max-tick-time=60000
require-resource-pack=false
use-native-transport=true
max-players=${max_players}
online-mode=${online_mode}
enable-status=true
allow-flight=false
initial-disabled-packs=
broadcast-rcon-to-ops=true
view-distance=10
server-ip=
resource-pack-prompt=
allow-nether=true
server-port=${port}
enable-rcon=false
sync-chunk-writes=true
op-permission-level=4
prevent-proxy-connections=false
hide-online-players=false
resource-pack=
entity-broadcast-range-percentage=100
simulation-distance=10
rcon.password=
player-idle-timeout=0
force-gamemode=false
rate-limit=0
hardcore=false
white-list=false
broadcast-console-to-ops=true
spawn-npcs=true
spawn-animals=true
function-permission-level=2
initial-enabled-packs=vanilla
level-type=minecraft\:normal
text-filtering-config=
spawn-monsters=true
enforce-whitelist=false
spawn-protection=16
resource-pack-sha1=
max-world-size=29999984
EOF
    fi

    # Ask for Aikar Flags
    local include_aikar="false"
    if prompt_yes_no "Enable Aikar's optimized Garbage Collection Flags for JVM?" "y"; then include_aikar="true"; fi

    local jvm_args=""
    if [ "$include_aikar" = "true" ]; then
        jvm_args="-XX:+UseG1GC -XX:+ParallelRefProcEnabled -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:+DisableExplicitGC -XX:+AlwaysPreTouch -XX:G1NewSizePercent=30 -XX:G1MaxNewSizePercent=40 -XX:G1HeapRegionSize=8M -XX:G1ReservePercent=20 -XX:InitiatingHeapOccupancyPercent=15 -XX:G1MixedGCLiveThresholdPercent=90 -XX:G1MixedGCCountTarget=4 -XX:G1HeapWastePercent=5 -XX:SurvivorRatio=32 -XX:MaxTenuringThreshold=1 -Dusing.aikars.flags=https://mcflags.emc.gs -Daikars.new.flags=true"
    fi

    # Create start.sh script
    local java_dir
    java_dir=$(dirname "$java_path")
    local path_inject=""
    if [ "$java_dir" != "." ] && [ "$java_dir" != "/usr/bin" ] && [ "$java_dir" != "/bin" ]; then
        path_inject="export PATH=\"${java_dir}:\$PATH\""
    fi

    cat > start.sh <<EOF
#!/usr/bin/env bash
# Generated by mcserver-installer (${DEVELOPER})
# Minecraft Server Auto-Restart script

${path_inject}

MEM_MIN="${min_ram}"
MEM_MAX="${max_ram}"

cd "\$(dirname "\$0")"

while [ ! -f .stop_restart ]; do
    echo "[mcserver-installer] Starting Minecraft server..."
EOF

    if [ "$final_jar" = "FORGE_RUN_SCRIPT" ] || [ "$final_jar" = "NEOFORGE_RUN_SCRIPT" ]; then
        # Modern Forge/NeoForge uses run.sh to launch, configure variables there
        # We edit user_jvm_args.txt to inject memory size and parameters
        if [ -f user_jvm_args.txt ]; then
            echo "-Xms${min_ram}" > user_jvm_args.txt
            echo "-Xmx${max_ram}" >> user_jvm_args.txt
            if [ -n "$jvm_args" ]; then
                echo "$jvm_args" >> user_jvm_args.txt
            fi
        fi
        echo "    bash run.sh nogui" >> start.sh
    else
        echo "    java -Xms\"\${MEM_MIN}\" -Xmx\"\${MEM_MAX}\" ${jvm_args} -jar ${final_jar} nogui" >> start.sh
    fi

    cat >> start.sh <<EOF
    if [ -f .stop_restart ]; then
        break
    fi
    echo "[mcserver-installer] Server stopped. Restarting in 5 seconds (Press Ctrl+C to cancel)..."
    sleep 5
done
rm -f .stop_restart
EOF

    chmod +x start.sh

    # Save details into local registry file
    local server_name
    server_name=$(basename "$inst_dir")
    # Clean duplicates in registry if path already exists
    if [ -f "$REGISTRY_FILE" ]; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^.*:$inst_dir:.*$||" "$REGISTRY_FILE"
        else
            sed -i "s|^.*:$inst_dir:.*$||" "$REGISTRY_FILE"
        fi
        # Remove empty lines
        sed_delete_blank_lines "$REGISTRY_FILE"
    fi
    echo "${server_name}:${inst_dir}:${s_type}:${mc_version}" >> "$REGISTRY_FILE"

    # Run backend orchestrator if proxy server software was installed
    if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
        orchestrate_proxy_network "$inst_dir" "$server_name" "$s_type" "$port"
    fi

    # Auto-start server
    log_info "Auto-starting server..."
    start_minecraft_server "$inst_dir"

    local session_name; session_name=$(get_session_name "$inst_dir")
    local start_status="false"
    if is_server_running "$session_name"; then
        start_status="true"
    fi

    echo -e "\n"
    local local_ip; local_ip=$(get_local_ip)
    local public_ip="Unknown"
    if [ -f "${CONFIG_DIR}/.public_ip" ]; then
        public_ip=$(cat "${CONFIG_DIR}/.public_ip" 2>/dev/null)
    fi
    [ -z "$public_ip" ] && public_ip="Unknown"

    if [ "$LANG_PREF" = "tr" ]; then
        draw_box_open "Kurulum Tamamlandı!"
        log_success "Sunucu türü: $s_type ($mc_version) başarıyla kuruldu."
        log_success "Dizin: $inst_dir"
        log_success "Çalıştırılabilir: ./start.sh"
        if [ "$start_status" = "true" ]; then
            log_success "✔ Sunucu arka planda başarıyla başlatıldı! (Ekran oturumu: $session_name)"
        fi
        if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
            echo -e ""
            log_success "👉 Oyuncu Giriş Adresi (Proxy): ${COLOR_GREEN}${public_ip}:${port}${COLOR_RESET} veya ${COLOR_GREEN}${local_ip}:${port}${COLOR_RESET}"
            log_warn "⚠️ ÖNEMLİ: Arka plan sunucularına doğrudan bağlanamazsınız. Sunucuya giriş yapmak için yukarıdaki PROXY portunu kullanmalısınız."
        fi
        log_info "Artık bu sunucuyu ana menüden başlatabilir ve yönetebilirsiniz!"
        draw_box_close
    else
        draw_box_open "Installation Complete!"
        log_success "Server type: $s_type ($mc_version) installed successfully."
        log_success "Path: $inst_dir"
        log_success "Executable: ./start.sh"
        if [ "$start_status" = "true" ]; then
            log_success "✔ Server started successfully in the background! (Screen session: $session_name)"
        fi
        if [ "$s_type" = "velocity" ] || [ "$s_type" = "waterfall" ] || [ "$s_type" = "bungeecord" ]; then
            echo -e ""
            log_success "👉 Player Connection Address (Proxy): ${COLOR_GREEN}${public_ip}:${port}${COLOR_RESET} or ${COLOR_GREEN}${local_ip}:${port}${COLOR_RESET}"
            log_warn "⚠️ IMPORTANT: Do NOT connect directly to backend ports. You must connect via the PROXY port listed above."
        fi
        log_info "You can now start and manage this server from the main menu!"
        draw_box_close
    fi

    echo -e -n "\n  $(t "press_enter_main" "Press [Enter] to return to the main menu: ")"
    read -r _
}

# --- Properties Editor ---
get_property_val() {
    local file="$1"
    local key="$2"
    grep "^${key}=" "$file" | cut -d= -f2-
}

set_property_val() {
    local file="$1"
    local key="$2"
    local val="$3"
    local escaped_val
    escaped_val=$(escape_sed_replacement "$val")
    if grep -q "^${key}=" "$file"; then
        if [[ "$OSTYPE" == "darwin"* ]]; then
            sed -i '' "s|^${key}=.*|${key}=${escaped_val}|" "$file"
        else
            sed -i "s|^${key}=.*|${key}=${escaped_val}|" "$file"
        fi
    else
        echo "${key}=${val}" >> "$file"
    fi
}

run_properties_editor() {
    local server_path="$1"
    local prop_file="${server_path}/server.properties"

    if [ ! -f "$prop_file" ]; then
        log_error "No server.properties file found at $server_path"
        echo -n "  Press [Enter] to return: "
        read -r _
        return 1
    fi

    while true; do
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_properties_editor" "SERVER PROPERTIES EDITOR")${COLOR_RESET}"
        echo -e "  Location: $prop_file"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

        # Read current configurations
        local port; port=$(get_property_val "$prop_file" "server-port")
        local motd; motd=$(get_property_val "$prop_file" "motd")
        local difficulty; difficulty=$(get_property_val "$prop_file" "difficulty")
        local gamemode; gamemode=$(get_property_val "$prop_file" "gamemode")
        local online; online=$(get_property_val "$prop_file" "online-mode")
        local pvp; pvp=$(get_property_val "$prop_file" "pvp")
        local whitelist; whitelist=$(get_property_val "$prop_file" "white-list")
        local players; players=$(get_property_val "$prop_file" "max-players")
        local flight; flight=$(get_property_val "$prop_file" "allow-flight")
        local spawn_prot; spawn_prot=$(get_property_val "$prop_file" "spawn-protection")

        # Defaults if empty
        [ -z "$port" ] && port="25565"
        [ -z "$online" ] && online="true"
        [ -z "$pvp" ] && pvp="true"
        [ -z "$whitelist" ] && whitelist="false"
        [ -z "$flight" ] && flight="false"
        [ -z "$spawn_prot" ] && spawn_prot="16"

        echo -e "    ${COLOR_YELLOW}1.${COLOR_RESET} Server Port       [${COLOR_GREEN}${port}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}2.${COLOR_RESET} Online Mode       [${COLOR_GREEN}${online}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}3.${COLOR_RESET} MOTD              [${COLOR_GREEN}${motd}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}4.${COLOR_RESET} Max Players       [${COLOR_GREEN}${players}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}5.${COLOR_RESET} Difficulty        [${COLOR_GREEN}${difficulty}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}6.${COLOR_RESET} Default GameMode  [${COLOR_GREEN}${gamemode}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}7.${COLOR_RESET} PVP Enabled       [${COLOR_GREEN}${pvp}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}8.${COLOR_RESET} Whitelist Mode    [${COLOR_GREEN}${whitelist}${COLOR_RESET}]"
        echo -e "    ${COLOR_YELLOW}9.${COLOR_RESET} Allow Flight      [${COLOR_GREEN}${flight}${COLOR_RESET}]"
        echo -e "   ${COLOR_YELLOW}10.${COLOR_RESET} Spawn Protection  [${COLOR_GREEN}${spawn_prot}${COLOR_RESET}]"
        echo -e "   ${COLOR_YELLOW}11.${COLOR_RESET} $(t "return_mgmt_menu" "Return to Management Menu")"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"

        echo -n "  Choose option (1-11): "
        read -r choice

        case "$choice" in
            1)
                local val; val=$(prompt_input "Enter server port" "$port")
                set_property_val "$prop_file" "server-port" "$val"
                ;;
            2)
                local val="true"
                if ! prompt_yes_no "Enable Online Mode?" "y"; then val="false"; fi
                set_property_val "$prop_file" "online-mode" "$val"
                ;;
            3)
                local val; val=$(prompt_input "Enter Server MOTD" "$motd")
                set_property_val "$prop_file" "motd" "$val"
                ;;
            4)
                local val; val=$(prompt_input "Enter Max Players" "$players")
                set_property_val "$prop_file" "max-players" "$val"
                ;;
            5)
                local val; val=$(prompt_selection "$(t "prompt_difficulty" "Select Difficulty:")" peaceful easy normal hard)
                set_property_val "$prop_file" "difficulty" "$val"
                ;;
            6)
                local val; val=$(prompt_selection "$(t "prompt_gamemode" "Select Default GameMode:")" survival creative adventure spectator)
                set_property_val "$prop_file" "gamemode" "$val"
                ;;
            7)
                local val="true"
                if ! prompt_yes_no "Enable PVP?" "y"; then val="false"; fi
                set_property_val "$prop_file" "pvp" "$val"
                ;;
            8)
                local val="true"
                if ! prompt_yes_no "Enable whitelist?" "n"; then val="false"; fi
                set_property_val "$prop_file" "white-list" "$val"
                ;;
            9)
                local val="true"
                if ! prompt_yes_no "Allow Flight?" "n"; then val="false"; fi
                set_property_val "$prop_file" "allow-flight" "$val"
                ;;
            10)
                local val; val=$(prompt_input "Enter spawn protection range" "$spawn_prot")
                set_property_val "$prop_file" "spawn-protection" "$val"
                ;;
            11)
                break
                ;;
            *)
                log_warn "Invalid selection."
                sleep 1
                ;;
        esac
    done
}

# --- Backup & Restore Subsystem ---
create_server_backup() {
    local server_path="$1"
    local backup_dir="${server_path}/backups"
    mkdir -p "$backup_dir"

    if [ "${HEADLESS_MODE:-false}" = "false" ]; then
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_backup_creation" "BACKUP CREATION")${COLOR_RESET}"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"
    fi

    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local tar_name="backup_${timestamp}.tar.gz"
    local tar_path="${backup_dir}/${tar_name}"

    log_info "$(t "backup_in_progress" "Creating backup archive in progress...")"

    (cd "$server_path" && tar --exclude='./backups' --exclude='./logs' -czf "$tar_path" .)
    local status=$?

    if [ $status -eq 0 ]; then
        local size_bytes
        if [[ "$OSTYPE" == "darwin"* ]]; then
            size_bytes=$(stat -f %z "$tar_path")
        else
            size_bytes=$(stat -c %s "$tar_path")
        fi
        local size_mb=$((size_bytes / 1024 / 1024))
        log_success "$(t "backup_success" "Backup completed successfully!")"
        log_success "$(t "backup_saved" "Saved as:") backups/${tar_name} (${size_mb} MB)"
        send_discord_notification "Backup created successfully." 3066993 "$server_path" "Backup Archive" "${tar_name} (${size_mb} MB)"
    else
        log_error "$(t "backup_failed" "Backup compression failed.")"
        send_discord_notification "Backup compression failed." 15158332 "$server_path"
    fi

    if [ "${HEADLESS_MODE:-false}" = "false" ]; then
        echo -e -n "\n  Press [Enter] to return: "
        read -r _
    fi
}

manage_backup_scheduler() {
    local s_name="$1"
    local s_path="$2"

    while true; do
        clear_screen
        draw_header
        echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_backup_scheduler" "AUTOMATED BACKUP SCHEDULER")${COLOR_RESET}"
        echo -e "  Server: $s_name"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

        local current_cron
        current_cron=$(crontab -l 2>/dev/null | grep -F "mcserver-installer" | grep -F -- "--backup" | grep -F -- "\"${s_name}\"" || true)

        if [ -n "$current_cron" ]; then
            local schedule_desc=""
            if echo "$current_cron" | grep -q "0 4 \* \* 0"; then
                schedule_desc=$(t "sched_weekly_desc" "Weekly (Sundays at 04:00 AM)")
            elif echo "$current_cron" | grep -q "0 4 \* \* \*"; then
                schedule_desc=$(t "sched_daily_desc" "Daily (at 04:00 AM)")
            else
                schedule_desc="$current_cron"
            fi
            echo -e "  $(t "sched_active" "Active Schedule: ") ${COLOR_GREEN}${schedule_desc}${COLOR_RESET}"
        else
            echo -e "  $(t "sched_active" "Active Schedule: ") ${COLOR_YELLOW}$(t "sched_none" "None (Disabled)")${COLOR_RESET}"
        fi

        echo -e "\n  $(t "sched_options" "Options:")"
        echo -e "    ${COLOR_YELLOW}1.${COLOR_RESET} $(t "sched_daily" "Schedule Daily Backup (at 04:00 AM)")"
        echo -e "    ${COLOR_YELLOW}2.${COLOR_RESET} $(t "sched_weekly" "Schedule Weekly Backup (Sundays at 04:00 AM)")"
        echo -e "    ${COLOR_YELLOW}3.${COLOR_RESET} $(t "sched_remove" "Remove Automated Backup Schedule")"
        echo -e "    ${COLOR_YELLOW}4.${COLOR_RESET} $(t "return_mgmt_menu" "Return to Management Menu")"
        echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}"

        local choice
        choice=$(prompt_input "$(t "main_select" "Select option")" "4")

        local script_path="$SCRIPT_PATH"

        case "$choice" in
            1)
                local schedule_line="0 4 * * * \"${script_path}\" --backup \"${s_name}\" >/dev/null 2>&1"
                (crontab -l 2>/dev/null | grep -Fv -- "--backup \"${s_name}\""; echo "$schedule_line") | crontab -
                log_success "$(t "sched_daily_success" "Daily backup successfully scheduled!")"
                sleep 2
                ;;
            2)
                local schedule_line="0 4 * * 0 \"${script_path}\" --backup \"${s_name}\" >/dev/null 2>&1"
                (crontab -l 2>/dev/null | grep -Fv -- "--backup \"${s_name}\""; echo "$schedule_line") | crontab -
                log_success "$(t "sched_weekly_success" "Weekly backup successfully scheduled!")"
                sleep 2
                ;;
            3)
                (crontab -l 2>/dev/null | grep -Fv -- "--backup \"${s_name}\"") | crontab - || crontab -r 2>/dev/null
                log_success "$(t "sched_remove_success" "Automated backup schedule removed.")"
                sleep 2
                ;;
            4)
                break
                ;;
            *)
                log_warn "$(t "invalid_sel" "Invalid selection.")"
                sleep 1.5
                ;;
        esac
    done
}

run_server_restore() {
    local server_path="$1"
    local backup_dir="${server_path}/backups"

    clear_screen
    draw_header
    echo -e "  ${COLOR_MAGENTA}${COLOR_BOLD}$(t "hdr_restore_backup" "RESTORE BACKUP")${COLOR_RESET}"
    echo -e "  ${COLOR_CYAN}================================================================${COLOR_RESET}\n"

    if [ ! -d "$backup_dir" ] || [ -z "$(ls -A "$backup_dir" 2>/dev/null)" ]; then
        log_warn "$(t "restore_none_found" "No backups found for this server.")"
        echo -e -n "\n  $(t "press_enter" "Press [Enter] to return: ")"
        read -r _
        return 1
    fi

    local backups_list=()
    for f in "$backup_dir"/backup_*.tar.gz; do
        if [ -f "$f" ]; then
            backups_list+=("$(basename "$f")")
        fi
    done

    if [ ${#backups_list[@]} -eq 0 ]; then
        log_warn "$(t "restore_invalid" "No valid backups found.")"
        echo -e -n "\n  $(t "press_enter" "Press [Enter] to return: ")"
        read -r _
        return 1
    fi

    # Sort backups in descending order (newest first)
    IFS=$'\n' sorted_backups=($(sort -r <<<"${backups_list[*]}"))
    unset IFS

    local chosen_backup
    chosen_backup=$(prompt_selection "$(t "prompt_restore_backup" "Select backup to restore:")" "${sorted_backups[@]}")
    local full_backup_path="${backup_dir}/${chosen_backup}"

    log_warn "$(t "restore_destructive" "RESTORE ACTION IS DESTRUCTIVE!")"
    log_warn "$(t "restore_warning" "This will overwrite your existing world files, properties, and configurations.")"

    local confirm_msg
    if [ "$LANG_PREF" = "tr" ]; then
        confirm_msg="${chosen_backup} yedeğini geri yüklemek istediğinizden kesinlikle emin misiniz?"
    else
        confirm_msg="Are you absolutely sure you want to restore ${chosen_backup}?"
    fi

    if ! prompt_yes_no "$confirm_msg" "n"; then
        log_info "$(t "restore_canceled" "Restore canceled.")"
        echo -e -n "\n  $(t "press_enter" "Press [Enter] to return: ")"
        read -r _
        return 0
    fi

    # We remove worlds and configs but keep logs and backup folder safe
    log_info "$(t "restore_clearing" "Clearing directory for restore...")"
    find "$server_path" -mindepth 1 -maxdepth 1 -not -name "backups" -not -name "logs" -exec rm -rf {} +

    log_info "$(t "restore_extracting" "Extracting backup content...")"
    tar -xzf "$full_backup_path" -C "$server_path"
    local status=$?

    if [ $status -eq 0 ]; then
        log_success "$(t "restore_success" "Backup restored successfully!")"
        log_info "$(t "restore_verify" "Please verify the start script and java configurations before starting.")"
    else
        log_error "$(t "restore_failed" "Failed to extract backup file correctly.")"
    fi

    echo -e -n "\n  $(t "press_enter" "Press [Enter] to return: ")"
    read -r _
}

# --- Server Lifecycle & Console Manager ---

get_session_name() {
    local s_path="$1"
    local hash
    if command -v md5sum &>/dev/null; then
        hash=$(echo -n "$s_path" | md5sum | cut -c1-8)
    else
        hash=$(echo -n "$s_path" | md5 | cut -c1-8)
    fi
    local name
    name=$(basename "$s_path" | tr -cd 'a-zA-Z0-9_-')
    echo "mc-${name}-${hash}"
}

is_server_running() {
    local session_name="$1"
    screen -list | grep -q "\.${session_name}"
}

check_firewall_rules() {
    local port="$1"
    if command -v ufw &>/dev/null; then
        local status
        status=$(sudo ufw status 2>/dev/null || ufw status 2>/dev/null || echo "inactive")
        if echo "$status" | grep -q "Status: active"; then
            if ! echo "$status" | grep -q "${port}"; then
                log_warn "UFW firewall is active but port ${port} is NOT allowed!"
                echo -n "  Would you like to open port ${port} in UFW automatically? [Y/n]: " >&2
                local choice
                read -r choice
                if [[ ! "$choice" =~ ^[Nn] ]]; then
                    local open_cmd="ufw allow ${port}/tcp && ufw allow ${port}/udp && ufw reload"
                    if [ "$EUID" -eq 0 ]; then
                        run_with_spinner "Opening port ${port} in UFW" bash -c "$open_cmd"
                    else
                        run_with_spinner "Opening port ${port} in UFW (via sudo)" sudo bash -c "$open_cmd"
                    fi
                fi
            else
                log_success "UFW firewall rule check: Port ${port} is already allowed."
            fi
        fi
    fi
}

start_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")

    if is_server_running "$session_name"; then
        log_warn "$(t "start_already_running" "Server is already running in screen session:") $session_name"
        sleep 2
        return 1
    fi

    local s_type="standard"
    local s_ver="latest"
    if [ -f "$REGISTRY_FILE" ]; then
        local abs_target
        abs_target=$(cd "$server_path" 2>/dev/null && pwd -P || echo "$server_path")
        while IFS=":" read -r r_name r_path r_type r_ver || [ -n "$r_name" ]; do
            [ -z "$r_name" ] && continue
            local abs_reg
            abs_reg=$(cd "$r_path" 2>/dev/null && pwd -P || echo "$r_path")
            if [ "$abs_target" = "$abs_reg" ]; then
                s_type="$r_type"
                s_ver="$r_ver"
                break
            fi
        done < "$REGISTRY_FILE"
    fi

    if [ "$s_type" = "standard" ] && [ -f "${server_path}/velocity.toml" ]; then
        s_type="velocity"
    elif [ "$s_type" = "standard" ] && [ -f "${server_path}/config.yml" ]; then
        s_type="bungeecord"
    fi

    if ! update_start_script_java_path "$server_path" "$s_type" "$s_ver"; then
        log_error "Java runtime setup failed. Cannot start server."
        sleep 2
        return 1
    fi

    local port; port=$(get_server_port "$server_path" "$s_type")
    check_firewall_rules "$port"

    log_info "$(t "start_in_progress" "Starting server...")"
    rm -f "${server_path}/.stop_restart"

    (cd "$server_path" && screen -dmS "$session_name" ./start.sh)

    sleep 2
    if is_server_running "$session_name"; then
        log_success "$(t "start_success" "Server started successfully in background!")"
        log_info "$(t "start_screen_session" "Screen session:") $session_name"
        send_discord_notification "Server started." 3066993 "$server_path"
    else
        log_error "$(t "start_failed" "Server failed to start. Check your logs/latest.log or start.sh.")"
    fi
    sleep 2
}

stop_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")

    if ! is_server_running "$session_name"; then
        log_warn "$(t "stop_not_running" "Server is not running.")"
        sleep 2
        return 1
    fi

    log_info "$(t "stop_sending_command" "Sending stop command to server...")"
    touch "${server_path}/.stop_restart"

    screen -S "$session_name" -p 0 -X stuff "stop$(printf \\r)"

    local count=0
    printf "  $(t "stop_waiting_graceful" "Waiting for server to stop gracefully ")"
    while is_server_running "$session_name" && [ $count -lt 30 ]; do
        printf "."
        sleep 1
        count=$((count + 1))
    done
    printf "\n"

    if is_server_running "$session_name"; then
        log_warn "$(t "stop_force_termination" "Server did not stop gracefully. Forcing termination...")"
        screen -S "$session_name" -p 0 -X quit
        pkill -f "java.*${session_name}"
        send_discord_notification "Server force-stopped." 15158332 "$server_path"
    else
        log_success "$(t "stop_success" "Server stopped gracefully.")"
        send_discord_notification "Server stopped." 15158332 "$server_path"
    fi
    rm -f "${server_path}/.stop_restart"
    sleep 2
}

restart_minecraft_server() {
    local server_path="$1"
    local session_name
    session_name=$(get_session_name "$server_path")

    if is_server_running "$session_name"; then
        stop_minecraft_server "$server_path"
    fi
    start_minecraft_server "$server_path"
}

